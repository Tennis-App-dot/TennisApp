<UserControl
    x:Class="TennisApp.Presentation.Dialogs.TraineeDetailCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="White"
            CornerRadius="16"
            Padding="32"
            Width="600"
            MinHeight="400"
            BorderBrush="#E0E0E0"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with close button -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="ผู้เรียน"
                           FontSize="24"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8"
                        Click="CloseButton_Click">
                    <FontIcon Glyph="&#xE711;" FontSize="16" Foreground="#666"/>
                </Button>
            </Grid>

            <!-- Profile Section -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Profile Image -->
                <Border Grid.Column="0"
                        Width="150"
                        Height="150"
                        CornerRadius="75"
                        Background="#E0E0E0"
                        Margin="0,0,24,0">
                    <Image x:Name="ProfileImage" 
                           Stretch="UniformToFill"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Border>

                <!-- Info Section -->
                <StackPanel Grid.Column="1" 
                            Spacing="12" 
                            VerticalAlignment="Center">
                    <TextBlock x:Name="TraineeIdText"
                               Text=""
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#333"/>

                    <TextBlock x:Name="NameText"
                               Text=""
                               FontSize="16"
                               Foreground="#555"/>

                    <TextBlock x:Name="NicknameText"
                               Text=""
                               FontSize="16"
                               Foreground="#555"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="BirthDateText"
                                   Grid.Column="0"
                                   Text=""
                                   FontSize="16"
                                   Foreground="#555"/>

                        <TextBlock x:Name="AgeText"
                                   Grid.Column="1"
                                   Text=""
                                   FontSize="16"
                                   Foreground="#555"
                                   Margin="32,0,0,0"/>
                    </Grid>

                    <TextBlock x:Name="PhoneText"
                               Text=""
                               FontSize="16"
                               Foreground="#555"/>
                </StackPanel>
            </Grid>

            <!-- Action Buttons -->
            <Grid Grid.Row="3" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ประวัติการสมัครเรียน -->
                <Button Grid.Column="0"
                        Content="ประวัติการสมัครเรียน"
                        Background="White"
                        Foreground="#4A148C"
                        BorderBrush="#4A148C"
                        BorderThickness="2"
                        Height="48"
                        CornerRadius="4"
                        FontSize="16"
                        Margin="0,0,16,0"
                        Click="HistoryButton_Click"/>

                <!-- แก้ไขและลบ (ชิดกัน) -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            Spacing="8">
                    <!-- แก้ไข -->
                    <Button Content="แก้ไข"
                            Background="#FFA726"
                            Foreground="White"
                            BorderThickness="0"
                            Height="48"
                            Width="120"
                            CornerRadius="4"
                            FontSize="16"
                            Click="EditButton_Click"/>

                    <!-- ลบ -->
                    <Button Content="ลบ"
                            Background="#EF5350"
                            Foreground="White"
                            BorderThickness="0"
                            Height="48"
                            Width="100"
                            CornerRadius="4"
                            FontSize="16"
                            Click="DeleteButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
