<ContentDialog
    x:Class="TennisApp.Presentation.Dialogs.CourtFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FontFamily="{StaticResource ThaiFontFamily}"
    CornerRadius="20"
    Background="#FFFFFF"
    BorderBrush="#E5E7EB"
    BorderThickness="1">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">320</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">600</x:Double>
        <Thickness x:Key="ContentDialogPadding">20,12,20,0</Thickness>
    </ContentDialog.Resources>

    <!-- Custom Title -->
    <ContentDialog.TitleTemplate>
        <DataTemplate>
            <Grid Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Background="#EEF2FF" CornerRadius="10" Width="40" Height="40"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE7C1;" FontSize="18" Foreground="#6C2BD9"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="ข้อมูลสนาม" 
                               FontSize="22" 
                               FontWeight="Bold"
                               FontFamily="{StaticResource ThaiFontFamilyBold}"
                               Foreground="#1A1A2E"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </ContentDialog.TitleTemplate>

    <!-- Main Content -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollMode="Auto"
                      HorizontalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Padding="4,8,4,8">

                <!-- รูปภาพสนาม -->
                <StackPanel Spacing="10">
                    <TextBlock Text="รูปภาพสนาม"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#374151"/>

                    <Border CornerRadius="12"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Background="#F9FAFB"
                            Height="180"
                            HorizontalAlignment="Stretch">
                        <Grid>
                            <Image x:Name="ImgPreview"
                                   Stretch="UniformToFill"
                                   Source="{Binding ImageSource, Mode=OneWay}"/>
                            <StackPanel x:Name="ImagePlaceholder"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="6"
                                        Visibility="Collapsed">
                                <FontIcon Glyph="&#xE722;" FontSize="32" Foreground="#D1D5DB"
                                          HorizontalAlignment="Center"/>
                                <TextBlock Text="ยังไม่มีรูปภาพ" FontSize="12" Foreground="#9CA3AF"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Click="ImageUploadButton_Click"
                                HorizontalAlignment="Stretch"
                                Background="#F0FDF4" Foreground="#16A34A"
                                CornerRadius="10"
                                Height="40"
                                FontSize="14"
                                FontWeight="SemiBold"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE898;" FontSize="14"/>
                                <TextBlock Text="อัปโหลดรูปภาพ" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Grid.Column="1"
                                   Text="JPEG / PNG ≤ 3MB"
                                   FontSize="11" Foreground="#9CA3AF"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1" Background="#F3F4F6"/>

                <!-- รหัสสนาม + สถานะ (2 คอลัมน์) -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- รหัสสนาม -->
                    <StackPanel Grid.Column="0" Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE71B;" FontSize="12" Foreground="#9CA3AF"/>
                            <TextBlock Text="รหัสสนาม (อัตโนมัติ)"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="#6B7280"/>
                        </StackPanel>
                        <TextBox Text="{Binding CourtID, Mode=OneWay}"
                                 IsReadOnly="True" IsEnabled="False"
                                 Background="#F3F4F6" Foreground="#6B7280"
                                 BorderBrush="#E5E7EB" CornerRadius="10"
                                 Height="42" FontSize="14"
                                 Padding="14,8"
                                 HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- สถานะ -->
                    <StackPanel Grid.Column="1" Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xEA38;" FontSize="12" Foreground="#9CA3AF"/>
                            <TextBlock Text="สถานะ"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="#374151"/>
                        </StackPanel>
                        <ComboBox SelectedValuePath="Tag"
                                  SelectedValue="{Binding Status, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  CornerRadius="10" Height="42" FontSize="14"
                                  BorderBrush="#E5E7EB">
                            <ComboBoxItem Content="พร้อมใช้งาน" Tag="1"/>
                            <ComboBoxItem Content="กำลังปิดปรับปรุง" Tag="0"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- วันที่ปรับปรุงสนาม (full width) -->
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE787;" FontSize="12" Foreground="#9CA3AF"/>
                        <TextBlock Text="วันที่ปรับปรุงสนาม"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="#374151"/>
                    </StackPanel>
                    <Border CornerRadius="10"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Height="42"
                            Background="Transparent">
                        <DatePicker Date="{Binding MaintenanceDateForPicker, Mode=TwoWay}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    BorderThickness="0"
                                    Background="Transparent"/>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Border Grid.Row="1"
                BorderThickness="0,1,0,0"
                BorderBrush="#F3F4F6"
                Background="#FAFBFC"
                CornerRadius="0,0,20,20">
            <Grid ColumnSpacing="12" Padding="4,14,4,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="CancelButton"
                        Grid.Column="0"
                        Click="CancelButton_Click"
                        Height="46"
                        Background="#F9FAFB" Foreground="#6B7280"
                        BorderBrush="#E5E7EB" CornerRadius="12"
                        FontSize="15"
                        BorderThickness="1"
                        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE711;" FontSize="14"/>
                        <TextBlock Text="ยกเลิก" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SaveButton"
                        Grid.Column="1"
                        Click="SaveButton_Click"
                        Height="46"
                        Background="#6C2BD9" Foreground="White"
                        CornerRadius="12" FontSize="15"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                        <TextBlock Text="บันทึก" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- แก้ไขข้อมูลล่าสุด -->
        <Border Grid.Row="2" Padding="4,0,4,6">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left">
                <FontIcon x:Name="LastModifiedIcon"
                          Glyph="&#xE823;" FontSize="11" Foreground="#9CA3AF"/>
                <TextBlock x:Name="LastModifiedTextBlock"
                           Text="{Binding LastModifiedText}"
                           FontSize="12" Foreground="#9CA3AF"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</ContentDialog>
