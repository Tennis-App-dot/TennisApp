<ContentDialog
    x:Class="TennisApp.Presentation.Dialogs.CourtFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FontFamily="{StaticResource ThaiFontFamily}"
    MinWidth="500"
    MaxWidth="800">
    <!-- Custom Title with Thai Font -->
    <ContentDialog.TitleTemplate>
        <DataTemplate>
            <TextBlock Text="ข้อมูลสนาม" 
                       FontSize="20" 
                       FontWeight="SemiBold"
                       FontFamily="{StaticResource ThaiFontFamilyBold}"
                       Foreground="Black"/>
        </DataTemplate>
    </ContentDialog.TitleTemplate>

    <!-- Grid with content and custom buttons -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content Section -->
        <ScrollViewer Grid.Row="0" VerticalScrollMode="Auto" HorizontalScrollMode="Disabled">
            <StackPanel Spacing="20" Padding="24,24,24,24">
                <!-- ชื่อสนาม -->
                <TextBlock Text="{Binding DisplayName}" 
                           FontSize="20" 
                           FontWeight="SemiBold"
                           Foreground="#333"
                           Margin="0,0,0,8"/>

                <!-- รูปภาพสนาม -->
                <StackPanel Spacing="12">
                    <Border CornerRadius="8" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1"
                            Background="#F8F8F8">
                        <Image x:Name="ImgPreview" 
                               Height="200" 
                               Stretch="UniformToFill"
                               Source="{Binding ImageSource, Mode=OneWay}"/>
                    </Border>
                    
                    <Button Content="อัปโหลดรูปภาพ"
                            Click="ImageUploadButton_Click"
                            HorizontalAlignment="Center"
                            Background="#4CAF50"
                            Foreground="White"
                            CornerRadius="6"
                            Padding="16,10"
                            FontSize="14"/>
                    
                    <TextBlock Text="ขนาดไฟล์ไม่เกิน 3MB  นามสกุล JPEG หรือ PNG"
                               FontSize="12"
                               Foreground="#666"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </StackPanel>

                <!-- ข้อมูลสนาม -->
                <StackPanel Spacing="16">
                    
                    <!-- รหัสสนาม (อัตโนมัติ) - Gray and Disabled -->
                    <StackPanel>
                        <TextBlock Text="รหัสสนาม (อัตโนมัติ)" 
                                   FontSize="14" 
                                   FontWeight="Medium"
                                   Foreground="#999"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding CourtID, Mode=OneWay}"
                                 IsReadOnly="True"
                                 IsEnabled="False"
                                 Background="#E8E8E8"
                                 Foreground="#666"
                                 BorderBrush="#CCCCCC"
                                 CornerRadius="6"
                                 Padding="12,10"
                                 />
                    </StackPanel>

                    <!-- สถานะ -->
                    <StackPanel>
                        <TextBlock Text="สถานะ" 
                                   FontSize="14" 
                                   FontWeight="Medium"
                                   Foreground="#555"
                                   Margin="0,0,0,6"/>
                        <ComboBox SelectedValuePath="Tag"
                                  SelectedValue="{Binding Status, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  CornerRadius="6"
                                  Padding="12,10"
                                  FontSize="14">
                            <ComboBoxItem Content="พร้อมใช้งาน" Tag="1"/>
                            <ComboBoxItem Content="กำลังปิดปรับปรุง" Tag="0"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- วันที่ปรับปรุงล่าสุด -->
                    <StackPanel>
                        <TextBlock Text="วันที่ปรับปรุงล่าสุด" 
                                   FontSize="14" 
                                   FontWeight="Medium"
                                   Foreground="#555"
                                   Margin="0,0,0,6"/>
                        
                        <!-- ✅ DatePicker สำหรับเลือกวันที่ปรับปรุง -->
                        <Border CornerRadius="6"
                                BorderBrush="#D0D0D0"
                                BorderThickness="1"
                                Height="44">
                            <DatePicker Date="{Binding LastUpdatedForDatePicker, Mode=TwoWay}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        BorderThickness="0"
                                        Background="Transparent"/>
                        </Border>
                    </StackPanel>

                   
                    
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Custom Buttons Section -->
        <Border Grid.Row="1" 
                BorderThickness="0,1,0,0" 
                BorderBrush="#E0E0E0"
                Background="#FAFAFA">
            <StackPanel Orientation="Horizontal" 
                        Spacing="12" 
                        HorizontalAlignment="Right" 
                        Padding="24,16,24,16">
                <Button x:Name="CancelButton" 
                        Content="ยกเลิก" 
                        Click="CancelButton_Click" 
                        MinWidth="100"
                        Height="40"
                        Background="#F5F5F5"
                        Foreground="#666"
                        BorderBrush="#D0D0D0"
                        CornerRadius="6"
                        FontSize="14"/>
                <Button x:Name="SaveButton" 
                        Content="บันทึก" 
                        Click="SaveButton_Click" 
                        MinWidth="100"
                        Height="40"
                        Background="#2196F3"
                        Foreground="White"
                        CornerRadius="6"
                        FontSize="14"
                        FontWeight="Medium"/>
            </StackPanel>
        </Border>

        <!-- แสดงเป็น "แก้ไขข้อมูลล่าสุด" ในบริบทของหน้า Edit -->
        <TextBlock x:Name="LastModifiedTextBlock"
                   Grid.Row="2"
                   Text="{Binding LastModifiedText}"
                   FontSize="12"
                   Foreground="Gray"
                   HorizontalAlignment="Left"
                   Margin="20,8,20,16"/>
    </Grid>
</ContentDialog>
