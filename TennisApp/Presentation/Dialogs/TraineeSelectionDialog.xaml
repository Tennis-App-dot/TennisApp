<ContentDialog
    x:Class="TennisApp.Presentation.Dialogs.TraineeSelectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    PrimaryButtonText="ยืนยันการเลือก"
    CloseButtonText="ยกเลิก"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    FontFamily="ms-appx:///Assets/Fonts/NotoSansThai-Regular.ttf#Noto Sans Thai"
    MinWidth="700"
    MaxHeight="650">

    <Grid HorizontalAlignment="Stretch" MinHeight="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <Grid Grid.Row="0" Margin="0,0,0,12" ColumnSpacing="8"
              HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     PlaceholderText="ค้นหาจากชื่อ, รหัส หรือชื่อเล่น..."
                     Background="White" Height="42"
                     VerticalContentAlignment="Center"
                     FontSize="14" CornerRadius="4"
                     BorderBrush="#E0E0E0" BorderThickness="1"
                     TextChanged="SearchBox_TextChanged"/>

            <Button Grid.Column="1"
                    Background="White" BorderBrush="#E0E0E0"
                    BorderThickness="1" Height="42" Width="42"
                    CornerRadius="4"
                    Click="BtnSearch_Click">
                <FontIcon Glyph="&#xE721;" FontSize="16" Foreground="#666"/>
            </Button>
        </Grid>

        <!-- Table (Header + Body) wrapped in horizontal ScrollViewer -->
        <Border Grid.Row="1"
                BorderBrush="#E0E0E0" BorderThickness="1"
                CornerRadius="6">
            <ScrollViewer HorizontalScrollMode="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled">
                <Grid MinWidth="580">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Table Header -->
                    <Grid Grid.Row="0" Background="#00E676"
                          MinHeight="40" Padding="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="เลือก"
                                   FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="รหัส"
                                   FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="ชื่อ-นามสกุล"
                                   FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="ชื่อเล่น"
                                   FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="เบอร์โทร"
                                   FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Table Body -->
                    <Grid Grid.Row="1">
                        <!-- Loading -->
                        <ProgressRing x:Name="LoadingRing"
                                      IsActive="False"
                                      Width="40" Height="40"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        <!-- No Results -->
                        <StackPanel x:Name="NoResultsPanel"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8"
                                    Visibility="Collapsed">
                            <FontIcon Glyph="&#xE11A;" FontSize="36" Foreground="#999"/>
                            <TextBlock Text="ไม่พบข้อมูล"
                                       FontSize="15" Foreground="#666"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Data List -->
                        <ListView x:Name="TraineeListView"
                                  SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="42" Padding="12,4"
                                          Background="White"
                                          BorderBrush="#F0F0F0"
                                          BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsAlreadyRegistered, Converter={StaticResource InverseBoolConverter}}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  MinWidth="0"
                                                  Checked="CheckBox_Changed"
                                                  Unchecked="CheckBox_Changed"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TraineeId}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Spacing="6">
                                            <TextBlock Text="{Binding FullName}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="(สมัครแล้ว)"
                                                       FontSize="11" Foreground="#EF5350"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IsAlreadyRegistered, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Nickname}"
                                                   FontSize="13" Foreground="#616161"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding Phone}"
                                                   FontSize="13" Foreground="#616161"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Footer: Selected count -->
        <Border Grid.Row="2" Margin="0,8,0,0"
                Background="#F5F5F5" CornerRadius="4"
                Padding="12,8">
            <TextBlock x:Name="TxtSelectedCount"
                       Text="เลือกแล้ว: 0 คน"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="#4A148C"/>
        </Border>
    </Grid>
</ContentDialog>
