<ContentDialog
    x:Class="TennisApp.Presentation.Dialogs.CourseRegistrationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    PrimaryButtonText="สมัครเรียน"
    CloseButtonText="ยกเลิก"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    FontFamily="ms-appx:///Assets/Fonts/NotoSansThai-Regular.ttf#Noto Sans Thai">

    <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" Padding="8">
            
            <!-- Trainee Profile Card -->
            <Border Background="#F5F5F5" 
                    CornerRadius="8" 
                    Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Profile Image -->
                    <Border Grid.Column="0"
                            Width="100"
                            Height="100"
                            CornerRadius="50"
                            Background="#E0E0E0"
                            Margin="0,0,20,0">
                        <Grid>
                            <Image x:Name="ProfileImage" 
                                   Stretch="UniformToFill"/>
                            <FontIcon x:Name="PlaceholderIcon"
                                      Glyph="&#xE77B;" 
                                      FontSize="48" 
                                      Foreground="#999"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Trainee Info -->
                    <StackPanel Grid.Column="1" 
                                Spacing="8" 
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TxtTraineeId"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#333"/>
                        
                        <TextBlock x:Name="TxtTraineeName"
                                   FontSize="14"
                                   Foreground="#555"/>
                        
                        <TextBlock x:Name="TxtTraineeNickname"
                                   FontSize="14"
                                   Foreground="#555"/>
                        
                        <TextBlock x:Name="TxtTraineePhone"
                                   FontSize="14"
                                   Foreground="#555"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Course Selection -->
            <StackPanel Spacing="12">
                <TextBlock Text="รหัสคอร์ส" 
                           FontSize="16"
                           FontWeight="SemiBold"/>
                
                <ComboBox x:Name="CmbCourse"
                          PlaceholderText="เลือกคอร์ส"
                          Background="White"
                          Height="45"
                          FontSize="16"
                          HorizontalAlignment="Stretch"
                          SelectionChanged="CmbCourse_SelectionChanged"/>
            </StackPanel>

            <!-- Course Details -->
            <Border x:Name="CourseDetailsPanel"
                    Background="#FFF9C4" 
                    CornerRadius="8" 
                    Padding="20"
                    Visibility="Collapsed">
                <StackPanel Spacing="12">
                    <TextBlock Text="ข้อมูลคอร์ส" 
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="ชื่อคอร์ส:" 
                                   FontSize="14"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtCourseName" 
                                   Grid.Row="0" Grid.Column="1"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" 
                                   Text="จำนวนครั้ง:" 
                                   FontSize="14"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtCourseSessions" 
                                   Grid.Row="1" Grid.Column="1"
                                   FontSize="14"
                                   Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" 
                                   Text="ระยะเวลาเรียน:" 
                                   FontSize="14"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtCourseDuration" 
                                   Grid.Row="2" Grid.Column="1"
                                   FontSize="14"
                                   Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" 
                                   Text="ค่าสมัคร:" 
                                   FontSize="14"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtCourseFee" 
                                   Grid.Row="3" Grid.Column="1"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#D32F2F"
                                   Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" 
                                   Text="ผู้ฝึกสอน:" 
                                   FontSize="14"/>
                        <TextBlock x:Name="TxtCourseTrainer" 
                                   Grid.Row="4" Grid.Column="1"
                                   FontSize="14"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
