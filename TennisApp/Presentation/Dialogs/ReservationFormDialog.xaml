<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="TennisApp.Presentation.Dialogs.ReservationFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:TennisApp.Models"
    FontFamily="{StaticResource ThaiFontFamily}"
    MinWidth="550"
    MaxWidth="800">

    <!-- Custom Title -->
    <ContentDialog.TitleTemplate>
        <DataTemplate>
            <TextBlock x:Name="DialogTitle"
                       Text="จองสนามเทนนิส" 
                       FontSize="20" 
                       FontWeight="SemiBold"
                       FontFamily="{StaticResource ThaiFontFamilyBold}"
                       Foreground="Black"/>
        </DataTemplate>
    </ContentDialog.TitleTemplate>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content Section -->
        <ScrollViewer Grid.Row="0" VerticalScrollMode="Auto" HorizontalScrollMode="Disabled">
            <StackPanel Spacing="20" Padding="24,24,24,24">

                <!-- 📅 วันที่ต้องการใช้สนาม -->
                <StackPanel>
                    <TextBlock Text="📅 วันที่ต้องการใช้สนาม" 
                               FontSize="14" 
                               FontWeight="Medium"
                               Foreground="#555"
                               Margin="0,0,0,6"/>
                    <Border CornerRadius="6"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            Height="44">
                        <DatePicker x:Name="ReserveDatePicker"
                                    Date="{x:Bind ReserveDateOffset, Mode=TwoWay}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    BorderThickness="0"
                                    Background="Transparent"/>
                    </Border>
                </StackPanel>

                <!-- ⏰ เวลาที่เข้าใช้สนาม -->
                <StackPanel>
                    <TextBlock Text="⏰ เวลาที่เข้าใช้สนาม" 
                               FontSize="14" 
                               FontWeight="Medium"
                               Foreground="#555"
                               Margin="0,0,0,6"/>
                    <Border CornerRadius="6"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            Height="44">
                        <TimePicker x:Name="ReserveTimePicker"
                                    Time="{x:Bind ReserveTime, Mode=TwoWay}"
                                    ClockIdentifier="24HourClock"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    BorderThickness="0"
                                    Background="Transparent"/>
                    </Border>
                </StackPanel>

                <!-- ⏱️ ระยะเวลาใช้สนาม -->
                <StackPanel>
                    <TextBlock Text="⏱️ ระยะเวลาใช้สนาม (ชั่วโมง)" 
                               FontSize="14" 
                               FontWeight="Medium"
                               Foreground="#555"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="DurationComboBox"
                              SelectedValue="{x:Bind Duration, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"
                              CornerRadius="6"
                              Padding="12,10"
                              FontSize="14"
                              SelectionChanged="DurationComboBox_SelectionChanged">
                        <ComboBox.Items>
                            <ComboBoxItem Content="1.0 ชั่วโมง" Tag="1.0"/>
                            <ComboBoxItem Content="1.5 ชั่วโมง" Tag="1.5"/>
                            <ComboBoxItem Content="2.0 ชั่วโมง" Tag="2.0"/>
                            <ComboBoxItem Content="2.5 ชั่วโมง" Tag="2.5"/>
                            <ComboBoxItem Content="3.0 ชั่วโมง" Tag="3.0"/>
                        </ComboBox.Items>
                    </ComboBox>
                </StackPanel>

                <!-- 🏁 ระยะเวลาที่คาดว่าสิ้นสุด (อ่านอย่างเดียว) -->
                <StackPanel>
                    <TextBlock Text="🏁 ระยะเวลาที่คาดว่าสิ้นสุด" 
                               FontSize="14" 
                               FontWeight="Medium"
                               Foreground="#555"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="EstimatedEndTimeTextBox"
                             Text="{x:Bind EstimatedEndTime, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="#F0F0F0"
                             Foreground="#666"
                             BorderBrush="#D0D0D0"
                             CornerRadius="6"
                             Padding="12,10"
                             FontSize="14"/>
                </StackPanel>

                <!-- 🎾 สนาม -->
                <StackPanel>
                    <TextBlock Text="🎾 สนาม" 
                               FontSize="14" 
                               FontWeight="Medium"
                               Foreground="#555"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="CourtComboBox"
                              SelectedValue="{x:Bind SelectedCourtId, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"
                              CornerRadius="6"
                              Padding="12,10"
                              FontSize="14"
                              SelectionChanged="CourtComboBox_SelectionChanged">
                        <!-- Items will be populated from code-behind -->
                    </ComboBox>
                </StackPanel>

                <!-- 📋 จุดประสงค์ -->
                <StackPanel>
                    <TextBlock Text="📋 จุดประสงค์" 
                               FontSize="14" 
                               FontWeight="Medium"
                               Foreground="#555"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="ReservationTypeComboBox"
                              SelectedValue="{x:Bind ReservationType, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"
                              CornerRadius="6"
                              Padding="12,10"
                              FontSize="14"
                              SelectionChanged="ReservationTypeComboBox_SelectionChanged">
                        <ComboBoxItem Content="จองแบบเช่า (คิดเงิน)" Tag="Paid"/>
                        <ComboBoxItem Content="จองสำหรับคอร์ส" Tag="Course"/>
                    </ComboBox>
                </StackPanel>

                <!-- 📚 คอร์สเรียน (แสดงเฉพาะเมื่อเลือก "จองสำหรับคอร์ส") -->
                <StackPanel x:Name="CourseSelectionPanel"
                            Visibility="Collapsed">
                    <TextBlock Text="📚 คอร์สเรียน" 
                               FontSize="14" 
                               FontWeight="Medium"
                               Foreground="#555"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="CourseComboBox"
                              SelectedValue="{x:Bind SelectedCourseId, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"
                              CornerRadius="6"
                              Padding="12,10"
                              FontSize="14"
                              SelectionChanged="CourseComboBox_SelectionChanged">
                        <!-- Items will be populated from code-behind -->
                    </ComboBox>
                </StackPanel>

                <!-- 👤 ชื่อผู้จอง -->
                <StackPanel>
                    <TextBlock Text="👤 ชื่อผู้จอง" 
                               FontSize="14" 
                               FontWeight="Medium"
                               Foreground="#555"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="CustomerNameTextBox"
                             Text="{x:Bind CustomerName, Mode=TwoWay}"
                             PlaceholderText="กรอกชื่อผู้จอง"
                             CornerRadius="6"
                             Padding="12,10"
                             FontSize="14"
                             BorderBrush="#D0D0D0"/>
                </StackPanel>

                <!-- 📞 เบอร์โทรศัพท์ -->
                <StackPanel>
                    <TextBlock Text="📞 เบอร์โทรศัพท์ (ไม่บังคับ)" 
                               FontSize="14" 
                               FontWeight="Medium"
                               Foreground="#555"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="CustomerPhoneTextBox"
                             Text="{x:Bind CustomerPhone, Mode=TwoWay}"
                             PlaceholderText="กรอกเบอร์โทรศัพท์ (10 หลัก)"
                             MaxLength="10"
                             InputScope="TelephoneNumber"
                             CornerRadius="6"
                             Padding="12,10"
                             FontSize="14"
                             BorderBrush="#D0D0D0"/>
                    <TextBlock Text="รูปแบบ: 0812345678"
                               FontSize="12"
                               Foreground="#999"
                               Margin="0,4,0,0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Custom Buttons Section -->
        <Border Grid.Row="1" 
                BorderThickness="0,1,0,0" 
                BorderBrush="#E0E0E0"
                Background="#FAFAFA">
            <StackPanel Orientation="Horizontal" 
                        Spacing="12" 
                        HorizontalAlignment="Right" 
                        Padding="24,16,24,16">
                <Button x:Name="CancelButton" 
                        Content="ยกเลิก" 
                        Click="CancelButton_Click" 
                        MinWidth="100"
                        Height="40"
                        Background="#F5F5F5"
                        Foreground="#666"
                        BorderBrush="#D0D0D0"
                        CornerRadius="6"
                        FontSize="14"/>
                <Button x:Name="SaveButton" 
                        Content="บันทึกการจอง" 
                        Click="SaveButton_Click" 
                        MinWidth="100"
                        Height="40"
                        Background="#2196F3"
                        Foreground="White"
                        CornerRadius="6"
                        FontSize="14"
                        FontWeight="Medium"/>
            </StackPanel>
        </Border>
    </Grid>
</ContentDialog>
