<Page
    x:Class="TennisApp.Presentation.Pages.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F5F5F5">

    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowSizeStates">
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeaderGrid.Padding" Value="14,12,14,0"/>
                        <Setter Target="HeaderTitle.FontSize" Value="22"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="600"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeaderGrid.Padding" Value="24,16,24,0"/>
                        <Setter Target="HeaderTitle.FontSize" Value="26"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Row 0: Header ══════════════════════════════ -->
        <Grid x:Name="HeaderGrid" Grid.Row="0" Padding="20,16,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="HeaderTitle" Grid.Column="0" Text="สรุปผลการดำเนินงาน" FontSize="26" FontWeight="SemiBold"
                       VerticalAlignment="Center" Foreground="#1A1A2E"/>
            <Button Grid.Column="1" x:Name="BtnExportPdf" Click="BtnExportPdf_Click"
                    Background="#4A148C" Foreground="White" FontSize="14"
                    Height="40" Padding="14,0" CornerRadius="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE78C;" FontSize="14" Foreground="White"/>
                    <TextBlock Text="PDF" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ══ Row 1: Period Filter + Date Range ═════════ -->
        <StackPanel Grid.Row="1" Margin="20,12,20,0" Spacing="8">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="PeriodFilterPanel" Orientation="Horizontal" Spacing="10"/>
            </ScrollViewer>

            <!-- 📅 Custom date range inline: [เริ่ม 📅] — [สิ้นสุด 📅] [🔍] -->
            <Border x:Name="CustomDatePanel" Visibility="Collapsed"
                    Background="White" CornerRadius="10"
                    BorderBrush="#E8E8E8" BorderThickness="1"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button x:Name="BtnPickStart" Click="BtnPickStart_Click"
                            Background="#F3E5F5" Foreground="#4A148C"
                            Height="36" Padding="12,0" CornerRadius="8"
                            BorderThickness="0" FontSize="13">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon Glyph="&#xE787;" FontSize="13" Foreground="#7B1FA2"/>
                            <TextBlock x:Name="TxtPickStart" Text="เริ่มต้น" FontSize="13"
                                       VerticalAlignment="Center" Foreground="#4A148C"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="—" FontSize="16" Foreground="#999"
                               VerticalAlignment="Center" Margin="2,0"/>
                    <Button x:Name="BtnPickEnd" Click="BtnPickEnd_Click"
                            Background="#E3F2FD" Foreground="#1565C0"
                            Height="36" Padding="12,0" CornerRadius="8"
                            BorderThickness="0" FontSize="13">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon Glyph="&#xE787;" FontSize="13" Foreground="#1565C0"/>
                            <TextBlock x:Name="TxtPickEnd" Text="สิ้นสุด" FontSize="13"
                                       VerticalAlignment="Center" Foreground="#1565C0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 📅 แสดงช่วงวันที่ + วงเล็บจำนวนวัน -->
            <TextBlock x:Name="TxtDateRange"
                       Text=""
                       FontSize="13" Foreground="#666666"
                       HorizontalAlignment="Left"
                       Margin="2,0,0,0"/>
        </StackPanel>

        <!-- ══ Row 2: Dashboard Content (ScrollViewer) ════ -->
        <Grid Grid.Row="2" Margin="20,8,20,0">
            <!-- Loading -->
            <ProgressRing x:Name="LoadingRing" IsActive="True"
                          Width="50" Height="50"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Content -->
            <ScrollViewer x:Name="ContentScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="Collapsed">
                <StackPanel x:Name="DashboardContent" Spacing="16" Padding="0,0,0,100">

                    <!-- Summary Cards 2x2 -->
                    <Grid x:Name="SummaryCardsGrid" ColumnSpacing="12" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 💰 รายได้รวม -->
                        <Border Grid.Row="0" Grid.Column="0" Background="#F3E5F5"
                                CornerRadius="14" Padding="18" MinHeight="110">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8CB;" FontSize="16" Foreground="#7B1FA2"/>
                                    <TextBlock Text="รายได้รวม" FontSize="13" Foreground="#7B1FA2" FontWeight="Medium"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtTotalRevenue" Text="฿0" FontSize="24"
                                           FontWeight="Bold" Foreground="#4A148C"/>
                                <TextBlock x:Name="TxtRevenueDetail" Text="จาก 0 ครั้ง" FontSize="11"
                                           Foreground="#9575CD"/>
                            </StackPanel>
                        </Border>

                        <!-- 📋 จองทั้งหมด -->
                        <Border Grid.Row="0" Grid.Column="1" Background="#E3F2FD"
                                CornerRadius="14" Padding="18" MinHeight="110">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE762;" FontSize="16" Foreground="#1565C0"/>
                                    <TextBlock Text="การจองรวม" FontSize="13" Foreground="#1565C0" FontWeight="Medium"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtTotalBookings" Text="0" FontSize="24"
                                           FontWeight="Bold" Foreground="#0D47A1"/>
                                <TextBlock x:Name="TxtBookingDetail" Text="Paid 0 / Course 0" FontSize="11"
                                           Foreground="#64B5F6"/>
                            </StackPanel>
                        </Border>

                        <!-- ✅ ใช้สนามจริง -->
                        <Border Grid.Row="1" Grid.Column="0" Background="#E8F5E9"
                                CornerRadius="14" Padding="18" MinHeight="110">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE73E;" FontSize="16" Foreground="#2E7D32"/>
                                    <TextBlock Text="ใช้สนามจริง" FontSize="13" Foreground="#2E7D32" FontWeight="Medium"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtTotalUsage" Text="0 ครั้ง" FontSize="24"
                                           FontWeight="Bold" Foreground="#1B5E20"/>
                                <TextBlock x:Name="TxtUsageDetail" Text="เฉลี่ย 0 ชม." FontSize="11"
                                           Foreground="#81C784"/>
                            </StackPanel>
                        </Border>

                        <!-- ❌ ยกเลิก -->
                        <Border Grid.Row="1" Grid.Column="1" Background="#FFEBEE"
                                CornerRadius="14" Padding="18" MinHeight="110">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE711;" FontSize="16" Foreground="#C62828"/>
                                    <TextBlock Text="ยกเลิก" FontSize="13" Foreground="#C62828" FontWeight="Medium"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtTotalCancelled" Text="0" FontSize="24"
                                           FontWeight="Bold" Foreground="#B71C1C"/>
                                <TextBlock x:Name="TxtCancelDetail" Text="0% ของทั้งหมด" FontSize="11"
                                           Foreground="#EF9A9A"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Detail Sections (built in code-behind) -->
                    <StackPanel x:Name="DetailSections" Spacing="16"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
