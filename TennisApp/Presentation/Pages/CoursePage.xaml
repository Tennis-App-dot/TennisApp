<Page
    x:Class="TennisApp.Presentation.Pages.CoursePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TennisApp.Presentation.Pages"
    xmlns:models="using:TennisApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <Grid Padding="40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="จัดการคอร์สเรียน"
                       FontSize="32" FontWeight="Bold"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    x:Name="AddButton"
                    Content="+ เพิ่มคอร์สใหม่"
                    Background="#4A148C" Foreground="White"
                    FontSize="16" Height="45"
                    Padding="24,0" CornerRadius="4"
                    Click="AddButton_Click"/>
        </Grid>

        <!-- ── Search Bar ─────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="0,0,0,16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- รหัสคอร์ส -->
            <TextBox x:Name="SearchClassIdBox"
                     Grid.Column="0"
                     PlaceholderText="รหัสคอร์ส..."
                     Background="White" Height="45"
                     VerticalContentAlignment="Center"
                     FontSize="15" CornerRadius="4"
                     BorderBrush="#E0E0E0" BorderThickness="1"
                     KeyDown="SearchBox_KeyDown"/>

            <!-- ชื่อคอร์ส -->
            <TextBox x:Name="SearchClassTitleBox"
                     Grid.Column="1"
                     PlaceholderText="ชื่อคอร์ส..."
                     Background="White" Height="45"
                     VerticalContentAlignment="Center"
                     FontSize="15" CornerRadius="4"
                     BorderBrush="#E0E0E0" BorderThickness="1"
                     KeyDown="SearchBox_KeyDown"/>

            <!-- ผู้รับผิดชอบ (ComboBox) -->
            <ComboBox x:Name="TrainerFilterComboBox"
                      Grid.Column="2"
                      PlaceholderText="ผู้รับผิดชอบ (ทั้งหมด)"
                      Background="White" Height="45"
                      MinWidth="180"
                      HorizontalAlignment="Stretch"
                      SelectionChanged="TrainerFilterComboBox_SelectionChanged"/>

            <!-- ปุ่มค้นหา -->
            <Button Grid.Column="3"
                    Background="White" BorderBrush="#E0E0E0"
                    BorderThickness="1" Height="45" Width="50"
                    CornerRadius="4" Click="BtnSearch_Click">
                <FontIcon Glyph="&#xE721;" FontSize="18" Foreground="#666"/>
            </Button>
        </Grid>

        <!-- ── Table ──────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <ScrollViewer HorizontalScrollMode="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled">
            <Grid MinWidth="1100">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Grid Grid.Row="0" Background="#00E676"
                      MinHeight="48" Padding="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>   <!-- รหัส -->
                        <ColumnDefinition Width="180"/>   <!-- ชื่อคอร์ส -->
                        <ColumnDefinition Width="160"/>   <!-- ผู้รับผิดชอบ -->
                        <ColumnDefinition Width="90"/>    <!-- ครั้งละ -->
                        <ColumnDefinition Width="90"/>    <!-- 4 ครั้ง -->
                        <ColumnDefinition Width="90"/>    <!-- 8 ครั้ง -->
                        <ColumnDefinition Width="90"/>    <!-- 12 ครั้ง -->
                        <ColumnDefinition Width="90"/>    <!-- 16 ครั้ง -->
                        <ColumnDefinition Width="100"/>   <!-- รายเดือน -->
                        <ColumnDefinition Width="80"/>    <!-- วันที่ -->
                        <ColumnDefinition Width="80"/>    <!-- จัดการ -->
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="รหัสคอร์ส"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="ชื่อคอร์ส"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="ผู้รับผิดชอบ"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="ครั้งละ"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="4" Text="4 ครั้ง"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="5" Text="8 ครั้ง"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="6" Text="12 ครั้ง"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="7" Text="16 ครั้ง"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="8" Text="รายเดือน"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="9" Text="วันที่"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="10" Text="จัดการ"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Grid>

                <!-- Loading -->
                <ProgressRing Grid.Row="1"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Width="48" Height="48"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Data rows -->
                <ListView Grid.Row="1"
                          x:Name="CoursesListView"
                          ItemsSource="{x:Bind ViewModel.FilteredCourses, Mode=OneWay}"
                          SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:CourseItem">
                            <Grid MinHeight="48" Padding="16,6"
                                  Background="White"
                                  BorderBrush="#F0F0F0"
                                  BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind ClassId}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ClassTitle}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind TrainerDisplayName}"
                                           FontSize="13" Foreground="#616161"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="3"
                                           Text="{x:Bind ClassRatePerTimeText}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Margin="0,0,12,0"/>

                                <TextBlock Grid.Column="4"
                                           Text="{x:Bind ClassRate4Text}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Margin="0,0,12,0"/>

                                <TextBlock Grid.Column="5"
                                           Text="{x:Bind ClassRate8Text}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Margin="0,0,12,0"/>

                                <TextBlock Grid.Column="6"
                                           Text="{x:Bind ClassRate12Text}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Margin="0,0,12,0"/>

                                <TextBlock Grid.Column="7"
                                           Text="{x:Bind ClassRate16Text}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Margin="0,0,12,0"/>

                                <TextBlock Grid.Column="8"
                                           Text="{x:Bind ClassRateMonthlyText}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Margin="0,0,12,0"/>

                                <TextBlock Grid.Column="9"
                                           Text="{x:Bind LastUpdatedText}"
                                           FontSize="12" Foreground="#9E9E9E"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>

                                <StackPanel Grid.Column="10"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="4">
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Width="34" Height="34"
                                            Padding="0"
                                            Click="BtnEdit_Click"
                                            Tag="{x:Bind ClassId}"
                                            Tapped="Button_Tapped">
                                        <FontIcon Glyph="&#xE70F;"
                                                  Foreground="#FFA726" FontSize="15"/>
                                    </Button>
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Width="34" Height="34"
                                            Padding="0"
                                            Click="BtnDelete_Click"
                                            Tag="{x:Bind ClassId}"
                                            Tapped="Button_Tapped">
                                        <FontIcon Glyph="&#xE74D;"
                                                  Foreground="#EF5350" FontSize="15"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
            </ScrollViewer>
        </Border>

        <!-- ── Footer ─────────────────────────────────────────── -->
        <TextBlock Grid.Row="3"
                   Text="หมายเหตุ ระยะเวลาเรียนคอร์สละ 1 ชั่วโมง"
                   FontSize="14" Foreground="#666"
                   Margin="0,16,0,0"
                   HorizontalAlignment="Left"/>
    </Grid>
</Page>
