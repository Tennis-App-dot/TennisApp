<Page
    x:Class="TennisApp.Presentation.Pages.CoursePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TennisApp.Presentation.Pages"
    xmlns:models="using:TennisApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <Grid Padding="40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="ข้อมูลคอร์ส" 
                   FontSize="32" 
                   FontWeight="Bold"
                   Margin="0,0,0,24"
                   VerticalAlignment="Center"/>

        <!-- Search Bar with Add Button -->
        <Grid Grid.Row="1" 
              Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Filter Dropdown -->
            <ComboBox x:Name="FilterComboBox"
                      Grid.Column="0"
                      PlaceholderText="ค้นหาจาก"
                      Background="White"
                      Height="45"
                      MinWidth="150"
                      Margin="0,0,20,0"
                      VerticalAlignment="Center"
                      SelectedIndex="0"
                      SelectionChanged="FilterComboBox_SelectionChanged">
                <ComboBoxItem Content="ทั้งหมด"/>
                <ComboBoxItem Content="รหัสคอร์ส"/>
                <ComboBoxItem Content="ชื่อคอร์ส"/>
                <ComboBoxItem Content="ผู้ฝึกสอน"/>
            </ComboBox>

            <!-- Search TextBox with Button -->
            <Grid Grid.Column="1" Margin="0,0,20,0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="SearchTextBox"
                         Grid.Column="0"
                         PlaceholderText="ค้นหา"
                         Background="White"
                         Height="45"
                         VerticalContentAlignment="Center"
                         FontSize="16"
                         BorderThickness="1"
                         BorderBrush="#E0E0E0"
                         CornerRadius="4"
                         KeyDown="SearchTextBox_KeyDown"/>

                <Button Grid.Column="1"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        Height="45"
                        Width="50"
                        CornerRadius="4"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="BtnSearch_Click">
                    <FontIcon Glyph="&#xE721;" FontSize="18" Foreground="#666666"/>
                </Button>
            </Grid>

            <!-- Add Button -->
            <Button x:Name="AddButton"
                    Grid.Column="2"
                    Content="เพิ่มคอร์สเรียน"
                    Background="#4A148C"
                    Foreground="White"
                    FontSize="16"
                    Height="45"
                    Padding="24,10"
                    CornerRadius="4"
                    Click="AddButton_Click"/>
        </Grid>

        <!-- Data Table -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="8"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Grid Grid.Row="0" 
                      Background="#00E676" 
                      MinHeight="50"
                      Padding="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="0.8*" MinWidth="60"/>
                        <ColumnDefinition Width="0.8*" MinWidth="60"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="รหัสคอร์ส" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="1" 
                               Text="ชื่อคอร์ส" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="2" 
                               Text="จำนวนครั้ง" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="3" 
                               Text="ค่าสมัครคอร์ส" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="4" 
                               Text="ผู้ฝึกสอน" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="5" 
                               Text="แก้ไข" 
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="6" 
                               Text="ลบ" 
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Table Body with ListView for data binding -->
                <ListView Grid.Row="1"
                          x:Name="CoursesListView"
                          ItemsSource="{x:Bind ViewModel.FilteredCourses, Mode=OneWay}"
                          SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:CourseItem">
                            <Grid MinHeight="50" 
                                  Padding="16,8" 
                                  Background="White"
                                  BorderBrush="#E0E0E0"
                                  BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="0.8*" MinWidth="60"/>
                                    <ColumnDefinition Width="0.8*" MinWidth="60"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="{x:Bind ClassId}" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" 
                                           Text="{x:Bind ClassTitle}" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" 
                                           Text="{x:Bind ClassTime}" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" 
                                           Text="{x:Bind ClassRate}" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" 
                                           Text="{x:Bind TrainerName}" 
                                           VerticalAlignment="Center"/>
                                
                                <Button Grid.Column="5" 
                                        Background="Transparent"
                                        HorizontalAlignment="Center"
                                        Click="BtnEdit_Click"
                                        Tag="{x:Bind ClassId}"
                                        Tapped="Button_Tapped">
                                    <FontIcon Glyph="&#xE70F;" Foreground="#FFA726" FontSize="18"/>
                                </Button>
                                
                                <Button Grid.Column="6" 
                                        Background="Transparent"
                                        HorizontalAlignment="Center"
                                        Click="BtnDelete_Click"
                                        Tag="{x:Bind ClassId}"
                                        Tapped="Button_Tapped">
                                    <FontIcon Glyph="&#xE74D;" Foreground="#EF5350" FontSize="18"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Footer Note -->
        <TextBlock Grid.Row="3"
                   Text="หมายเหตุ ระยะเวลาเรียนคอร์สละ 1 ชั่วโมง"
                   FontSize="14"
                   Foreground="#666"
                   Margin="0,16,0,0"
                   HorizontalAlignment="Left"/>
    </Grid>
</Page>
