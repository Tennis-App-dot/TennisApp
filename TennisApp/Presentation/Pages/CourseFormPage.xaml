<Page
    x:Class="TennisApp.Presentation.Pages.CourseFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TennisApp.Presentation.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5"
    FontFamily="ms-appx:///Assets/Fonts/NotoSansThai-Regular.ttf#Noto Sans Thai">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Padding="40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Header ══════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Background="Transparent" BorderThickness="0"
                    Padding="0,0,12,0" Click="BtnCancel_Click"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE76B;" FontSize="18" Foreground="#424242"/>
                    <TextBlock Text="กลับ" FontSize="15" Foreground="#424242"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock Grid.Column="1"
                       Text="เพิ่มคอร์สใหม่"
                       FontSize="28" FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
        </Grid>

        <!-- ══ Section 1: เลือกคอร์ส ═════════════════════════ -->
        <Border Grid.Row="1"
                Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1"
                Padding="32,24" Margin="0,0,0,20">
            <StackPanel Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                    <Border Background="#4A148C" CornerRadius="14" Width="28" Height="28">
                        <TextBlock Text="1" FontSize="14" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="เลือกคอร์ส"
                               FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Border Background="#F5F5F5" Height="1" Margin="0,0,0,4"/>

                <!-- ประเภทคอร์ส -->
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ประเภทคอร์ส" FontSize="15"/>
                        <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                    </StackPanel>
                    <ComboBox x:Name="CmbCourseType"
                              Background="White" Height="48"
                              HorizontalAlignment="Stretch" FontSize="15"
                              PlaceholderText="เลือกประเภทคอร์ส"
                              BorderBrush="#E0E0E0"
                              SelectionChanged="CmbCourseType_SelectionChanged"/>
                </StackPanel>

                <!-- จำนวนครั้ง -->
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="จำนวนครั้ง" FontSize="15"/>
                        <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                    </StackPanel>
                    <ComboBox x:Name="CmbSessionCount"
                              Background="White" Height="48"
                              HorizontalAlignment="Stretch" FontSize="15"
                              PlaceholderText="เลือกจำนวนครั้ง"
                              BorderBrush="#E0E0E0"
                              IsEnabled="False"
                              SelectionChanged="CmbSessionCount_SelectionChanged"/>
                </StackPanel>

                <!-- ผู้ฝึกสอน -->
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ผู้ฝึกสอน" FontSize="15"/>
                        <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                    </StackPanel>
                    <ComboBox x:Name="CmbTrainer"
                              Background="White" Height="48"
                              HorizontalAlignment="Stretch" FontSize="15"
                              PlaceholderText="เลือกผู้ฝึกสอน"
                              BorderBrush="#E0E0E0"
                              SelectionChanged="CmbTrainer_SelectionChanged"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ Section 2: สรุปข้อมูล (อ่านอย่างเดียว) ════════ -->
        <Border x:Name="SummarySection" Grid.Row="2"
                Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1"
                Padding="32,24" Margin="0,0,0,20"
                Visibility="Collapsed">
            <StackPanel Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                    <Border Background="#4A148C" CornerRadius="14" Width="28" Height="28">
                        <TextBlock Text="2" FontSize="14" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="สรุปข้อมูลคอร์ส"
                               FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Border Background="#F5F5F5" Height="1" Margin="0,0,0,4"/>

                <!-- Summary Card -->
                <Border Background="#F3E5F5" CornerRadius="10" Padding="20,16">
                    <Grid RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="รหัสคอร์ส" FontSize="14" Foreground="#757575"/>
                        <TextBlock x:Name="TxtSummaryClassId" Grid.Row="0" Grid.Column="1" FontSize="16" FontWeight="Bold" Foreground="#4A148C"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="ชื่อคอร์ส" FontSize="14" Foreground="#757575"/>
                        <TextBlock x:Name="TxtSummaryTitle" Grid.Row="1" Grid.Column="1" FontSize="15" Foreground="#1A1A2E"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="จำนวนครั้ง" FontSize="14" Foreground="#757575"/>
                        <TextBlock x:Name="TxtSummarySessions" Grid.Row="2" Grid.Column="1" FontSize="15" Foreground="#1A1A2E"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="ราคา" FontSize="14" Foreground="#757575"/>
                        <TextBlock x:Name="TxtSummaryPrice" Grid.Row="3" Grid.Column="1" FontSize="18" FontWeight="Bold" Foreground="#D32F2F"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="ผู้ฝึกสอน" FontSize="14" Foreground="#757575"/>
                        <TextBlock x:Name="TxtSummaryTrainer" Grid.Row="4" Grid.Column="1" FontSize="15" Foreground="#1A1A2E"/>
                    </Grid>
                </Border>

                <!-- Warning: duplicate -->
                <Border x:Name="DuplicateWarning"
                        Background="#FFF3E0" CornerRadius="8" Padding="16,10"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7BA;" FontSize="18" Foreground="#E65100"/>
                        <TextBlock x:Name="TxtDuplicateWarning"
                                   Text="คอร์สนี้ + ผู้ฝึกสอนคนนี้มีอยู่แล้วในระบบ"
                                   FontSize="14" Foreground="#E65100"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══ Buttons ═════════════════════════════════════════ -->
        <Grid Grid.Row="3" Margin="0,0,0,40">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="16">
                <Button x:Name="BtnCancel"
                        Content="ยกเลิก"
                        Background="White" Foreground="#424242"
                        BorderBrush="#E0E0E0" BorderThickness="1"
                        FontSize="16" Height="46"
                        Padding="32,0" CornerRadius="6"
                        Click="BtnCancel_Click"/>
                <Button x:Name="BtnSave"
                        Content="บันทึกข้อมูล"
                        Background="#4A148C" Foreground="White"
                        FontSize="16" Height="46"
                        Padding="32,0" CornerRadius="6"
                        Click="BtnSave_Click"
                        IsEnabled="False"/>
            </StackPanel>
        </Grid>

    </Grid>
    </ScrollViewer>
</Page>
