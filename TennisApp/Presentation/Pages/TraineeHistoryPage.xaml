<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TennisApp.Presentation.Pages.TraineeHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:TennisApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <Grid Padding="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="ประวัติผู้เรียน"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <!-- Trainee Profile Card -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="24"
                Margin="0,0,0,16"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Profile Image -->
                <Border Grid.Column="0"
                        Width="100" Height="100"
                        CornerRadius="50"
                        Background="#E8EAF6">
                    <Grid>
                        <Image x:Name="ProfileImage" Stretch="UniformToFill"/>
                        <FontIcon x:Name="PlaceholderIcon"
                                  Glyph="&#xE77B;"
                                  FontSize="48"
                                  Foreground="#9E9E9E"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Trainee Info -->
                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTraineeName"
                               FontSize="20" FontWeight="SemiBold" Foreground="#212121"/>
                    <TextBlock x:Name="TxtTraineeId"
                               FontSize="13" Foreground="#757575"/>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock x:Name="TxtTraineeNickname"
                                   FontSize="14" Foreground="#555"/>
                        <TextBlock x:Name="TxtPhone"
                                   FontSize="14" Foreground="#555"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock x:Name="TxtBirthDate"
                                   FontSize="14" Foreground="#555"/>
                        <TextBlock x:Name="TxtAge"
                                   FontSize="14" Foreground="#555"/>
                    </StackPanel>
                </StackPanel>

                <!-- Summary Badge -->
                <Border Grid.Column="2"
                        Background="#E8F5E9"
                        CornerRadius="10"
                        Padding="20,12"
                        VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock x:Name="TxtTotalCourses"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="#2E7D32"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="คอร์สที่ลงเรียน"
                                   FontSize="12" Foreground="#388E3C"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Registration List -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0"
                        Background="#4CAF50"
                        CornerRadius="12,12,0,0"
                        Padding="20,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="วันที่สมัคร"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Grid.Column="1" Text="รหัส"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Grid.Column="2" Text="ชื่อคอร์ส"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Grid.Column="3" Text="จำนวนครั้ง"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="ค่าเรียน"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="5" Text="ผู้สอน"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   Margin="16,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Loading / Empty / List -->
                <Grid Grid.Row="1">
                    <ProgressRing x:Name="LoadingRing"
                                  IsActive="False"
                                  Width="48" Height="48"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>

                    <StackPanel x:Name="NoResultsPanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="12"
                                Visibility="Collapsed">
                        <FontIcon Glyph="&#xE11A;" FontSize="48" Foreground="#BDBDBD"/>
                        <TextBlock Text="ยังไม่มีประวัติการลงเรียน"
                                   FontSize="16" Foreground="#9E9E9E"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ListView x:Name="RegistrationListView"
                              SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ClassRegisRecordItem">
                                <Border Padding="20,14"
                                        BorderBrush="#F0F0F0"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="160"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- วันที่สมัคร -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind RegisDateFormatted}"
                                                   FontSize="14" Foreground="#424242"
                                                   VerticalAlignment="Center"/>

                                        <!-- รหัสคอร์ส -->
                                        <Border Grid.Column="1"
                                                Background="#E3F2FD"
                                                CornerRadius="6"
                                                Padding="8,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind ClassId}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#1565C0"/>
                                        </Border>

                                        <!-- ชื่อคอร์ส -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind ClassName}"
                                                   FontSize="14" Foreground="#212121"
                                                   VerticalAlignment="Center"/>

                                        <!-- จำนวนครั้ง -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{x:Bind ClassTimeText}"
                                                   FontSize="14" Foreground="#424242"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <!-- ค่าเรียน -->
                                        <TextBlock Grid.Column="4"
                                                   Text="{x:Bind ClassRateText}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#C62828"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>

                                        <!-- ผู้สอน -->
                                        <StackPanel Grid.Column="5"
                                                    Orientation="Horizontal"
                                                    Spacing="6"
                                                    Margin="16,0,0,0"
                                                    VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE77B;"
                                                      FontSize="14"
                                                      Foreground="#757575"/>
                                            <TextBlock Text="{x:Bind TrainerDisplayName}"
                                                       FontSize="14" Foreground="#424242"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
