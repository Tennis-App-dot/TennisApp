<Page
    x:Class="TennisApp.Presentation.Pages.TraineeEditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TennisApp.Presentation.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F2F4F7">

    <Grid x:Name="RootGrid" Padding="20,10">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowSizeStates">
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="14,8"/>
                        <Setter Target="HeaderTitle.FontSize" Value="24"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="600"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="28,14"/>
                        <Setter Target="HeaderTitle.FontSize" Value="28"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Background="Transparent" BorderThickness="0"
                    Padding="0,0,10,0" Click="BtnCancel_Click"
                    VerticalAlignment="Center"
                    MinHeight="48">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE76B;" FontSize="20" Foreground="#424242"/>
                    <TextBlock Text="กลับ" FontSize="18" Foreground="#424242"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock x:Name="HeaderTitle"
                       Grid.Column="1"
                       Text="แก้ไขผู้เรียน"
                       FontSize="26" FontWeight="ExtraBold"
                       Foreground="#1A1A2E"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>
        </Grid>

        <!-- Main Card -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
            <Border Background="White" CornerRadius="16"
                    BorderBrush="#E5E7EB" BorderThickness="1"
                    Padding="28,24"
                    VerticalAlignment="Top"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Stretch">

                <Grid ColumnSpacing="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Photo -->
                    <StackPanel Grid.Column="0" Spacing="12"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Width="140">
                        <Border Width="120" Height="120"
                                Background="#E8EAF6"
                                CornerRadius="60"
                                HorizontalAlignment="Center">
                            <Grid>
                                <Image x:Name="ProfileImage"
                                       Stretch="UniformToFill"
                                       Visibility="Collapsed"/>
                                <Viewbox x:Name="PlaceholderIcon"
                                         Width="70" Height="70"
                                         Visibility="Visible">
                                    <Canvas Width="24" Height="24">
                                        <Ellipse Canvas.Left="8" Canvas.Top="4"
                                                 Width="8" Height="8"
                                                 Fill="#9CA3AF"/>
                                        <Path Data="M12 14 C8 14, 4 16, 4 20 L20 20 C20 16, 16 14, 12 14 Z"
                                              Fill="#9CA3AF"/>
                                    </Canvas>
                                </Viewbox>
                            </Grid>
                        </Border>
                        <Button x:Name="BtnUploadPhoto"
                                Click="BtnUploadPhoto_Click"
                                HorizontalAlignment="Stretch"
                                Background="#EEF2FF" Foreground="#6C2BD9"
                                CornerRadius="10" Height="42"
                                FontSize="14" FontWeight="SemiBold"
                                BorderBrush="#C7D2FE" BorderThickness="1"
                                Padding="8,0">
                            <TextBlock Text="📷 แก้ไขรูป" FontSize="14"
                                       HorizontalAlignment="Center"/>
                        </Button>
                        <TextBlock Text="JPEG / PNG ≤ 3MB"
                                   FontSize="12" Foreground="#9CA3AF"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: Form -->
                    <Grid Grid.Column="1" RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ชื่อ" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold" FontSize="16"/>
                                </StackPanel>
                                <TextBox x:Name="TxtFirstName"
                                         Background="White" Height="52" FontSize="17"
                                         VerticalContentAlignment="Center"
                                         BorderBrush="#E5E7EB" CornerRadius="10"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="นามสกุล" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold" FontSize="16"/>
                                </StackPanel>
                                <TextBox x:Name="TxtLastName"
                                         Background="White" Height="52" FontSize="17"
                                         VerticalContentAlignment="Center"
                                         BorderBrush="#E5E7EB" CornerRadius="10"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="ชื่อเล่น" FontSize="16" FontWeight="SemiBold"/>
                                <TextBox x:Name="TxtNickname"
                                         Background="White" Height="52" FontSize="17"
                                         VerticalContentAlignment="Center"
                                         BorderBrush="#E5E7EB" CornerRadius="10"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="เบอร์โทรศัพท์" FontSize="16" FontWeight="SemiBold"/>
                                <TextBox x:Name="TxtPhone"
                                         Background="White" Height="52" FontSize="17"
                                         VerticalContentAlignment="Center"
                                         BorderBrush="#E5E7EB" CornerRadius="10"
                                         InputScope="TelephoneNumber"
                                         MaxLength="10"
                                         TextChanged="TxtPhone_TextChanged"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="วันเกิด" FontSize="16" FontWeight="SemiBold"/>
                                <Button x:Name="BtnPickBirthDate"
                                        Click="BtnPickBirthDate_Click"
                                        HorizontalAlignment="Stretch"
                                        Background="White" Height="52"
                                        BorderBrush="#E5E7EB" CornerRadius="10"
                                        HorizontalContentAlignment="Left"
                                        Padding="14,0">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE787;" FontSize="16" Foreground="#9CA3AF"/>
                                        <TextBlock x:Name="TxtBirthDateDisplay"
                                                   Text="เลือกวันเกิด"
                                                   FontSize="17" Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                                    Spacing="12" Margin="0,10,0,0"
                                    HorizontalAlignment="Right">
                            <Button x:Name="BtnCancel"
                                    Content="ยกเลิก"
                                    Background="White" Foreground="#6B7280"
                                    FontSize="17" Height="54" CornerRadius="12"
                                    BorderBrush="#E5E7EB" BorderThickness="1"
                                    Padding="32,0"
                                    Click="BtnCancel_Click"/>
                            <Button x:Name="BtnSave"
                                    Content="บันทึกข้อมูล"
                                    Background="#6C2BD9" Foreground="White"
                                    FontSize="17" FontWeight="SemiBold"
                                    Height="54" CornerRadius="12"
                                    BorderThickness="0"
                                    Padding="32,0"
                                    Click="BtnSave_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            <!-- Keyboard spacer -->
            <Border x:Name="KeyboardSpacer" Height="0" Background="Transparent"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
