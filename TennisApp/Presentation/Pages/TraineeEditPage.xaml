<Page
    x:Class="TennisApp.Presentation.Pages.TraineeEditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TennisApp.Presentation.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <Grid x:Name="RootGrid" Padding="40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Visual State Manager for Responsive Design -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowSizeStates">
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="16,16"/>
                        <Setter Target="HeaderText.FontSize" Value="24"/>
                        <Setter Target="FormContainer.Padding" Value="20"/>
                        <Setter Target="TitleText.FontSize" Value="20"/>
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="MediumState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="720"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="24,20"/>
                        <Setter Target="HeaderText.FontSize" Value="28"/>
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1024"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="40,20"/>
                        <Setter Target="HeaderText.FontSize" Value="32"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Header -->
        <TextBlock x:Name="HeaderText"
                   Grid.Row="0" 
                   Text="ผู้เรียน" 
                   FontSize="32" 
                   FontWeight="Bold"
                   Margin="0,0,0,24"/>

        <!-- Form Container -->
        <Border x:Name="FormContainer"
                Grid.Row="1" 
                Background="#8BC34A" 
                CornerRadius="8"
                Padding="40">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <Grid MaxWidth="900">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Title -->
                        <TextBlock x:Name="TitleText"
                                   Grid.Row="0" 
                                   Text="แก้ไขทะเบียนประวัติผู้เรียน"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,30"/>

                        <!-- Form Content -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Side: Profile Photo -->
                            <StackPanel Grid.Column="0" 
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Center">
                                
                                <!-- Profile Photo Circle -->
                                <Border Width="150" 
                                        Height="150"
                                        Background="#FF7043"
                                        CornerRadius="75"
                                        Margin="0,0,0,16">
                                    <Grid>
                                        <!-- Profile Image -->
                                        <Image x:Name="ProfileImage"
                                               Stretch="UniformToFill"
                                               Visibility="Collapsed"/>
                                        
                                        <!-- Avatar Image Placeholder -->
                                        <Viewbox x:Name="PlaceholderIcon" 
                                                 Width="100" 
                                                 Height="100"
                                                 Visibility="Visible">
                                            <Canvas Width="24" Height="24">
                                                <!-- Simple person icon illustration -->
                                                <Ellipse Canvas.Left="8" Canvas.Top="4" 
                                                         Width="8" Height="8" 
                                                         Fill="White"/>
                                                <Path Data="M12 14 C8 14, 4 16, 4 20 L20 20 C20 16, 16 14, 12 14 Z" 
                                                      Fill="White"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Grid>
                                </Border>

                                <!-- Upload Photo Button -->
                                <Button x:Name="BtnUploadPhoto"
                                        Background="#1A237E"
                                        Foreground="White"
                                        FontSize="14"
                                        Padding="20,10"
                                        CornerRadius="4"
                                        HorizontalAlignment="Center"
                                        Click="BtnUploadPhoto_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8B9;" FontSize="16"/>
                                        <TextBlock Text="แก้ไขรูปภาพ"/>
                                    </StackPanel>
                                </Button>

                                <!-- Upload Info Text -->
                                <TextBlock Text="ขนาดไฟล์ไม่เกิน 3MB นามสกุล JPEG หรือ PNG"
                                           FontSize="11"
                                           Foreground="#333333"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           MaxWidth="160"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- Right Side: Form Fields -->
                            <StackPanel Grid.Column="2" 
                                        Spacing="20"
                                        VerticalAlignment="Top">
                                
                                <!-- Row 1: ชื่อ and นามสกุล -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="ชื่อ" 
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <TextBox x:Name="TxtFirstName"
                                                 Background="White"
                                                 Height="40"
                                                 VerticalContentAlignment="Center"
                                                 FontSize="14"
                                                 BorderBrush="#E0E0E0"
                                                 CornerRadius="4"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="นามสกุล" 
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <TextBox x:Name="TxtLastName"
                                                 Background="White"
                                                 Height="40"
                                                 VerticalContentAlignment="Center"
                                                 FontSize="14"
                                                 BorderBrush="#E0E0E0"
                                                 CornerRadius="4"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 2: เบอร์โทรศัพท์ and ชื่อเล่น -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="เบอร์โทรศัพท์" 
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <TextBox x:Name="TxtPhone"
                                                 Background="White"
                                                 Height="40"
                                                 VerticalContentAlignment="Center"
                                                 FontSize="14"
                                                 BorderBrush="#E0E0E0"
                                                 CornerRadius="4"
                                                 InputScope="Number"
                                                 MaxLength="10"
                                                 TextChanged="TxtPhone_TextChanged"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="ชื่อเล่น" 
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <TextBox x:Name="TxtNickname"
                                                 Background="White"
                                                 Height="40"
                                                 VerticalContentAlignment="Center"
                                                 FontSize="14"
                                                 BorderBrush="#E0E0E0"
                                                 CornerRadius="4"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 3: วันเกิด -->
                                <StackPanel>
                                    <TextBlock Text="วันเกิด" 
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>
                                    <DatePicker x:Name="DateBirthDate"
                                                Background="White"
                                                Height="40"
                                                HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center"
                                                BorderBrush="#E0E0E0"
                                                CornerRadius="4"/>
                                </StackPanel>

                            </StackPanel>
                        </Grid>

                    </Grid>
                </ScrollViewer>
                
                <!-- Action Buttons -->
                <StackPanel Grid.Row="1" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Spacing="20"
                            Margin="0,20,0,0">
                    
                    <Button x:Name="BtnCancel"
                            Content="ยกเลิก"
                            Background="#1A237E"
                            Foreground="White"
                            FontSize="16"
                            Padding="40,12"
                            MinWidth="150"
                            CornerRadius="4"
                            Click="BtnCancel_Click"/>
                    
                    <Button x:Name="BtnSave"
                            Content="บันทึก"
                            Background="#1A237E"
                            Foreground="White"
                            FontSize="16"
                            Padding="40,12"
                            MinWidth="150"
                            CornerRadius="4"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Page>
