<Page
    x:Class="TennisApp.Presentation.Pages.TrainerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TennisApp.Presentation.Pages"
    xmlns:dialogs="using:TennisApp.Presentation.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F2F4F7">

    <Grid x:Name="RootGrid" Padding="16,14">

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowSizeStates">
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="12,10"/>
                        <Setter Target="HeaderTitle.FontSize" Value="22"/>
                        <Setter Target="AddButton.Height" Value="44"/>
                        <Setter Target="AddButton.Padding" Value="16,0"/>
                        <Setter Target="AddButtonText.FontSize" Value="14"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="600"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="24,18"/>
                        <Setter Target="HeaderTitle.FontSize" Value="26"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="HeaderTitle"
                       Text="จัดการทะเบียนผู้ฝึกสอน"
                       FontSize="26" FontWeight="ExtraBold"
                       Foreground="#1A1A2E"
                       VerticalAlignment="Center"/>

            <Button x:Name="AddButton" Grid.Column="1"
                    Click="BtnAddTrainer_Click"
                    Background="#6C2BD9" Foreground="White"
                    Height="52" FontSize="16" FontWeight="Bold"
                    Padding="28,0" CornerRadius="14"
                    BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE710;" FontSize="18"/>
                    <TextBlock x:Name="AddButtonText"
                               Text="เพิ่มผู้ฝึกสอน" VerticalAlignment="Center"
                               FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ── Search Bar ─────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnSpacing="8" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchTextBox"
                     Grid.Column="0"
                     Text="{x:Bind ViewModel.SearchKeyword, Mode=TwoWay}"
                     PlaceholderText="ค้นหาชื่อ, รหัส, เบอร์โทร..."
                     Background="White"
                     Height="44"
                     VerticalContentAlignment="Center"
                     FontSize="15"
                     BorderThickness="1"
                     BorderBrush="#E5E7EB"
                     CornerRadius="10"
                     KeyDown="SearchTextBox_KeyDown"/>

            <Button Grid.Column="1"
                    Command="{x:Bind ViewModel.SearchCommand}"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Height="44" Width="48"
                    CornerRadius="10">
                <FontIcon Glyph="&#xE721;" FontSize="18" Foreground="#6B7280"/>
            </Button>
        </Grid>

        <!-- ── Trainer Card List ──────────────────────────── -->
        <Grid Grid.Row="2">
            <!-- Loading -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="50" Height="50"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>

            <!-- Empty State -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12"
                        Visibility="{x:Bind ViewModel.HasNoResults, Mode=OneWay}">
                <FontIcon Glyph="&#xE77B;" FontSize="64" Foreground="#D1D5DB"/>
                <TextBlock Text="ยังไม่มีข้อมูลผู้ฝึกสอน"
                           FontSize="18" Foreground="#9CA3AF"
                           HorizontalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text="กดปุ่ม &quot;เพิ่มผู้ฝึกสอน&quot; เพื่อเริ่มต้น"
                           FontSize="14" Foreground="#D1D5DB"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Card ListView -->
            <ListView x:Name="TrainersListView"
                      ItemsSource="{x:Bind ViewModel.Trainers, Mode=OneWay}"
                      SelectionMode="None"
                      Visibility="{x:Bind ViewModel.HasNoResults, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,12"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White"
                                CornerRadius="14"
                                Padding="0"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                MinHeight="100"
                                Tapped="TrainerRow_Tapped">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Profile Image (left) -->
                                <Border Grid.Column="0"
                                        Width="90" Height="90"
                                        CornerRadius="45"
                                        Background="#E8EAF6"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center">
                                    <Grid>
                                        <FontIcon Glyph="&#xE77B;" FontSize="36"
                                                  Foreground="#9CA3AF"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        <Image Source="{Binding ImageSource}"
                                               Stretch="UniformToFill"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Info (center) -->
                                <StackPanel Grid.Column="1"
                                            Spacing="4"
                                            Padding="16,14"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FullName}"
                                               FontSize="17" FontWeight="Bold"
                                               Foreground="#1A1A2E"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding Nickname}"
                                                   FontSize="14" Foreground="#6B7280"
                                                   Visibility="{Binding HasNickname, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE717;" FontSize="13" Foreground="#9CA3AF"/>
                                        <TextBlock Text="{Binding Phone}"
                                                   FontSize="14" Foreground="#6B7280"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TrainerId}"
                                               FontSize="12" Foreground="#9CA3AF"/>
                                </StackPanel>

                                <!-- Action Buttons (right) -->
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center"
                                            Margin="0,0,12,0">
                                    <Button Background="#EEF2FF"
                                            Foreground="#6C2BD9"
                                            CornerRadius="12"
                                            Width="44" Height="44"
                                            Padding="0"
                                            BorderThickness="0"
                                            Click="BtnEditTrainer_Click"
                                            Tapped="Button_Tapped"
                                            Tag="{Binding TrainerId}"
                                            ToolTipService.ToolTip="แก้ไข">
                                        <FontIcon Glyph="&#xE70F;" FontSize="16"/>
                                    </Button>
                                    <Button Background="#FEF2F2"
                                            Foreground="#DC2626"
                                            CornerRadius="12"
                                            Width="44" Height="44"
                                            Padding="0"
                                            BorderThickness="0"
                                            Click="BtnDeleteTrainer_Click"
                                            Tapped="Button_Tapped"
                                            Tag="{Binding TrainerId}"
                                            ToolTipService.ToolTip="ลบ">
                                        <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>

                <!-- Load More Footer -->
                <ListView.Footer>
                    <Button Command="{Binding DataContext.LoadMoreCommand, ElementName=TrainersListView}"
                            Content="โหลดเพิ่มเติม..."
                            HorizontalAlignment="Center"
                            Margin="0,8,0,16"
                            Padding="32,12"
                            Height="48"
                            Background="#6C2BD9" Foreground="White"
                            CornerRadius="12"
                            Visibility="{x:Bind ViewModel.HasMoreData, Mode=OneWay}"/>
                </ListView.Footer>
            </ListView>
        </Grid>

        <!-- Detail Card Overlay -->
        <Grid x:Name="DetailOverlay" 
              Grid.RowSpan="3"
              Background="#80000000"
              Visibility="Collapsed"
              Tapped="DetailOverlay_Tapped">
            <dialogs:TrainerDetailCard x:Name="DetailCard"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Tapped="DetailCard_Tapped"/>
        </Grid>
    </Grid>
</Page>
