<Page
    x:Class="TennisApp.Presentation.Pages.TraineeFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TennisApp.Presentation.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <Grid Padding="40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="ผู้เรียน" 
                   FontSize="32" 
                   FontWeight="Bold"
                   Margin="0,0,0,30"/>

        <!-- Form Container -->
        <Border Grid.Row="1" 
                Background="#8BC34A" 
                CornerRadius="8"
                Padding="40">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0" 
                           Text="สร้างทะเบียนประวัติผู้เรียน"
                           FontSize="24"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- Form Content -->
                <Grid Grid.Row="1" MaxWidth="800">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Profile Photo -->
                    <Border Grid.Row="0" 
                            Grid.Column="0"
                            Width="150" 
                            Height="150"
                            Background="#E0E0E0"
                            CornerRadius="75"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <Grid>
                            <!-- Profile Image -->
                            <Image x:Name="ProfileImage"
                                   Stretch="UniformToFill"
                                   Visibility="Collapsed"/>
                            
                            <!-- Upload Icon Placeholder -->
                            <Button x:Name="BtnUploadPhoto"
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Click="BtnUploadPhoto_Click">
                                <FontIcon x:Name="PlaceholderIcon" 
                                          Glyph="&#xE710;" 
                                          FontSize="40" 
                                          Foreground="#666666"/>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="ขนาดไฟล์ไม่เกิน 3MB&#x0a;นามสกุล JPEG หรือ PNG"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#333333"
                               HorizontalAlignment="Left"
                               TextAlignment="Center"
                               Width="150"
                               Margin="0,-50,0,0"/>

                    <!-- Form Fields -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="20">
                        
                        <!-- Row 1: Name and Surname -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="ชื่อ"/>
                                    <TextBlock Text=" *" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBox x:Name="TxtFirstName"
                                         PlaceholderText="กรอกชื่อ"
                                         Background="White"
                                         Height="35"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="นามสกุล"/>
                                    <TextBlock Text=" *" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBox x:Name="TxtLastName"
                                         PlaceholderText="กรอกนามสกุล"
                                         Background="White"
                                         Height="35"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2: Phone and Nickname -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="เบอร์โทรศัพท์" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtPhone"
                                         PlaceholderText="0xx-xxx-xxxx"
                                         Background="White"
                                         Height="35"
                                         InputScope="Number"
                                         MaxLength="10"
                                         TextChanged="TxtPhone_TextChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ชื่อเล่น" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtNickname"
                                         PlaceholderText="กรอกชื่อเล่น"
                                         Background="White"
                                         Height="35"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 3: Birth Date -->
                        <StackPanel>
                            <TextBlock Text="วันเกิด" Margin="0,0,0,5"/>
                            <DatePicker x:Name="DateBirthDate"
                                        Background="White"
                                        Height="35"
                                        HorizontalAlignment="Left"
                                        Width="200"/>
                        </StackPanel>

                    </StackPanel>

                </Grid>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Spacing="20"
                            Margin="0,40,0,0">
                    
                    <Button Content="ยกเลิก"
                            Background="#1A237E"
                            Foreground="White"
                            FontSize="16"
                            Padding="40,12"
                            MinWidth="150"
                            CornerRadius="4"
                            Click="BtnCancel_Click"/>
                    
                    <Button Content="บันทึก"
                            Background="#1A237E"
                            Foreground="White"
                            FontSize="16"
                            Padding="40,12"
                            MinWidth="150"
                            CornerRadius="4"
                            Click="BtnSave_Click"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</Page>
