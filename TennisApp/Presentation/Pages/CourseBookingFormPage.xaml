<Page
    x:Class="TennisApp.Presentation.Pages.CourseBookingFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Header ═══════════════════════════════════════ -->
        <Grid Grid.Row="0" Padding="20,14,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="BtnBack_Click"
                    Background="Transparent" BorderThickness="0"
                    Padding="0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE76B;" FontSize="18" Foreground="#424242"/>
                    <TextBlock Text="กลับ" FontSize="14" Foreground="#424242"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock Grid.Column="1" x:Name="HeaderText" Text="จองสนามคอร์ส"
                       FontSize="24" FontWeight="Bold" Foreground="#333"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
        </Grid>

        <!-- ══ Scrollable Form ══════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
            <StackPanel Spacing="12" Margin="20,0,20,20">

                <!-- ── Section: เลือกคอร์ส ─────────────────── -->
                <Border Background="White" CornerRadius="12"
                        BorderBrush="#E8E8E8" BorderThickness="1"
                        Padding="16,14">
                    <StackPanel Spacing="10">

                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE82D;" FontSize="14" Foreground="#4A148C"/>
                            <TextBlock Text="เลือกคอร์สเรียน" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                        </StackPanel>

                        <!-- Search -->
                        <TextBox x:Name="CourseSearchBox"
                                 PlaceholderText="ค้นหาคอร์ส / รหัส / โค้ช..."
                                 Background="White" Height="40"
                                 BorderBrush="#E0E0E0" CornerRadius="6"
                                 FontSize="14" VerticalContentAlignment="Center"
                                 TextChanged="CourseSearchBox_TextChanged"/>

                        <!-- Course List -->
                        <ListView x:Name="CourseListView"
                                  MaxHeight="180"
                                  SelectionMode="Single"
                                  SelectionChanged="CourseListView_SelectionChanged">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>

                    </StackPanel>
                </Border>

                <!-- ── Section: วัน-เวลา + ผู้จอง + ปุ่ม ────── -->
                <Border Background="White" CornerRadius="12"
                        BorderBrush="#E8E8E8" BorderThickness="1"
                        Padding="16,14">
                    <StackPanel Spacing="16">

                        <!-- วันที่ -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="6">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE787;" FontSize="14" Foreground="#4A148C" Margin="0,0,6,0"/>
                                    <TextBlock Text="วันที่ใช้สนาม" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                                </StackPanel>
                                <Button x:Name="BtnPickDate"
                                        Click="BtnPickDate_Click"
                                        HorizontalAlignment="Stretch"
                                        Background="White" Height="48"
                                        BorderBrush="#E0E0E0" CornerRadius="10"
                                        HorizontalContentAlignment="Left"
                                        Padding="14,0">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE787;" FontSize="15" Foreground="#9CA3AF"/>
                                        <TextBlock x:Name="TxtDateDisplay"
                                                   Text="เลือกวันที่"
                                                   FontSize="15" Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- เวลาเริ่ม + เวลาสิ้นสุด -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="6">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE823;" FontSize="14" Foreground="#4A148C" Margin="0,0,6,0"/>
                                    <TextBlock Text="เวลาเริ่ม" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                                </StackPanel>
                                <ComboBox x:Name="FormTimeComboBox"
                                          Background="White" Height="48"
                                          HorizontalAlignment="Stretch"
                                          BorderBrush="#E0E0E0" CornerRadius="6"
                                          PlaceholderText="เลือกเวลา" FontSize="15"
                                          SelectionChanged="StartTime_Changed">
                                    <ComboBoxItem Content="06:00" Tag="06:00"/>
                                    <ComboBoxItem Content="07:00" Tag="07:00"/>
                                    <ComboBoxItem Content="08:00" Tag="08:00"/>
                                    <ComboBoxItem Content="09:00" Tag="09:00"/>
                                    <ComboBoxItem Content="10:00" Tag="10:00"/>
                                    <ComboBoxItem Content="11:00" Tag="11:00"/>
                                    <ComboBoxItem Content="12:00" Tag="12:00"/>
                                    <ComboBoxItem Content="13:00" Tag="13:00"/>
                                    <ComboBoxItem Content="14:00" Tag="14:00"/>
                                    <ComboBoxItem Content="15:00" Tag="15:00"/>
                                    <ComboBoxItem Content="16:00" Tag="16:00"/>
                                    <ComboBoxItem Content="17:00" Tag="17:00"/>
                                    <ComboBoxItem Content="18:00" Tag="18:00"/>
                                    <ComboBoxItem Content="19:00" Tag="19:00"/>
                                    <ComboBoxItem Content="20:00" Tag="20:00"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="6">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE916;" FontSize="14" Foreground="#4A148C" Margin="0,0,6,0"/>
                                    <TextBlock Text="เวลาสิ้นสุด" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                                </StackPanel>
                                <ComboBox x:Name="FormEndTimeComboBox"
                                          Background="White" Height="48"
                                          HorizontalAlignment="Stretch"
                                          BorderBrush="#E0E0E0" CornerRadius="6"
                                          PlaceholderText="เลือกเวลาสิ้นสุด" FontSize="15"
                                          SelectionChanged="EndTime_Changed"/>
                            </StackPanel>
                        </Grid>

                        <!-- End Time Preview -->
                        <Border x:Name="EndTimePanel" Background="#F3E5F5" CornerRadius="6"
                                Padding="12,8" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE76C;" FontSize="12" Foreground="#7B1FA2"/>
                                <TextBlock x:Name="EndTimePreviewText" FontSize="13"
                                           Foreground="#4A148C" FontWeight="SemiBold"
                                           Text="--:-- → --:-- (0.0 ชม.)"/>
                            </StackPanel>
                        </Border>

                        <!-- Divider -->
                        <Border Background="#F0F0F0" Height="1"/>

                        <!-- ชื่อผู้จอง -->
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE77B;" FontSize="14" Foreground="#4A148C" Margin="0,0,6,0"/>
                                <TextBlock Text="ชื่อผู้จอง" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBox x:Name="FormNameTextBox"
                                     PlaceholderText="กรอกชื่อผู้จอง"
                                     Background="White" Height="48"
                                     BorderBrush="#E0E0E0" CornerRadius="6"
                                     FontSize="15" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- เบอร์โทร -->
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE717;" FontSize="14" Foreground="#999" Margin="0,0,6,0"/>
                                <TextBlock Text="เบอร์โทรศัพท์" FontSize="15" Foreground="#666"/>
                            </StackPanel>
                            <TextBox x:Name="FormPhoneTextBox"
                                     PlaceholderText="0812345678"
                                     Background="White" Height="48"
                                     BorderBrush="#E0E0E0" CornerRadius="6"
                                     FontSize="15" MaxLength="10"
                                     InputScope="TelephoneNumber"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- Divider -->
                        <Border Background="#F0F0F0" Height="1" Margin="0,4"/>

                        <!-- ══ Buttons (ล่างสุดของ card ชิดขวา) ═══ -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="12" Margin="0,8,0,0">
                            <Button Content="ยกเลิก"
                                    Background="White" Foreground="#424242"
                                    BorderBrush="#E0E0E0" BorderThickness="1"
                                    FontSize="15" Height="46"
                                    Padding="28,0" CornerRadius="10"
                                    Click="BtnBack_Click"/>
                            <Button Click="BtnSubmit_Click"
                                    Background="#4A148C" Foreground="White"
                                    FontSize="15" Height="46"
                                    Padding="28,0" CornerRadius="10"
                                    BorderThickness="0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="White"/>
                                    <TextBlock x:Name="SubmitButtonText" Text="ยืนยันจอง" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </Border>

            </StackPanel>
            <!-- Keyboard spacer -->
            <Border x:Name="KeyboardSpacer" Height="0" Background="Transparent"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
