<Page
    x:Class="TennisApp.Presentation.Pages.CourtUsageLogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TennisApp.Presentation.Pages"
    xmlns:viewmodels="using:TennisApp.Presentation.ViewModels"
    xmlns:models="using:TennisApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowSizeStates">
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeaderTitle.FontSize" Value="20"/>
                        <Setter Target="HeaderTitle.Margin" Value="14,12,14,0"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="600"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeaderTitle.FontSize" Value="24"/>
                        <Setter Target="HeaderTitle.Margin" Value="24,16,24,0"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Row 0: Header ══════════════════════════════════ -->
        <TextBlock x:Name="HeaderTitle" Grid.Row="0" Text="บันทึกการเข้าใช้งาน"
                   FontSize="24" FontWeight="Bold" Foreground="#333"
                   Margin="20,16,20,0"/>

        <!-- ══ Row 1: Tab Switcher ════════════════════════════ -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
                Margin="20,12,20,0" Padding="4"
                BorderBrush="#E8E8E8" BorderThickness="1">
            <Grid ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="TabCourtStatus" Grid.Column="0"
                        Click="TabCourtStatus_Click"
                        Background="#4A148C" Foreground="White"
                        HorizontalAlignment="Stretch" Height="40"
                        CornerRadius="8" BorderThickness="0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE707;" FontSize="14"/>
                        <TextBlock Text="สถานะสนาม" FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button x:Name="TabCheckIn" Grid.Column="1"
                        Click="TabCheckIn_Click"
                        Background="Transparent" Foreground="#666"
                        HorizontalAlignment="Stretch" Height="40"
                        CornerRadius="8" BorderThickness="0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8FA;" FontSize="14"/>
                        <TextBlock Text="เช็คอิน" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ══ Row 2: Content Area ════════════════════════════ -->
        <Grid Grid.Row="2" Margin="20,12,20,0">

            <!-- ═══ TAB 1: Court Status ═══════════════════════ -->
            <ScrollViewer x:Name="CourtStatusTab" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10" Padding="0,0,0,30">
                    <ListView x:Name="CourtStatusListView"
                              SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ TAB 2: Check-in ═══════════════════════════ -->
            <ScrollViewer x:Name="CheckInTab" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12" Padding="0,0,0,30">

                    <!-- Mode Toggle: จากการจอง / Walk-in -->
                    <Border Background="White" CornerRadius="10"
                            Padding="4" BorderBrush="#E8E8E8" BorderThickness="1">
                        <Grid ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ModeReservation" Grid.Column="0"
                                    Click="ModeReservation_Click"
                                    Background="#4A148C" Foreground="White"
                                    HorizontalAlignment="Stretch" Height="38"
                                    CornerRadius="8" BorderThickness="0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE787;" FontSize="13"/>
                                    <TextBlock Text="จากการจอง" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="ModeWalkIn" Grid.Column="1"
                                    Click="ModeWalkIn_Click"
                                    Background="Transparent" Foreground="#666"
                                    HorizontalAlignment="Stretch" Height="38"
                                    CornerRadius="8" BorderThickness="0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE716;" FontSize="13"/>
                                    <TextBlock Text="Walk-in" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ── Mode: จากการจอง ────────────────── -->
                    <StackPanel x:Name="ReservationModePanel" Spacing="12">

                        <!-- Date Navigator -->
                        <Border Background="White" CornerRadius="10"
                                Padding="10,8" BorderBrush="#E8E8E8" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Click="BtnPrevDate_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Width="40" Height="40" Padding="0" CornerRadius="20">
                                    <FontIcon Glyph="&#xE76B;" FontSize="16" Foreground="#555"/>
                                </Button>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center"
                                            VerticalAlignment="Center" Spacing="2">
                                    <TextBlock x:Name="CheckInDateText" Text="วันนี้ — 20/06/2025"
                                               FontSize="15" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Foreground="#333"/>
                                    <TextBlock x:Name="CheckInDayText" Text="วันศุกร์"
                                               FontSize="11" Foreground="#999"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="2" Click="BtnNextDate_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Width="40" Height="40" Padding="0" CornerRadius="20">
                                    <FontIcon Glyph="&#xE76C;" FontSize="16" Foreground="#555"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Reservation List -->
                        <ListView x:Name="BookedReservationsListView"
                                  SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>

                        <!-- Empty reservation state -->
                        <StackPanel x:Name="EmptyReservationPanel" Visibility="Collapsed"
                                    HorizontalAlignment="Center" Spacing="6" Padding="0,20">
                            <FontIcon Glyph="&#xE783;" FontSize="36" Foreground="#CCC"
                                      HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EmptyReservationText"
                                       Text="ไม่มีรายการจองวันนี้"
                                       FontSize="14" Foreground="#999"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Selected reservation preview + Court select -->
                        <Border x:Name="SelectedReservationPanel" Visibility="Collapsed"
                                Background="#F3E5F5" CornerRadius="10" Padding="16,14"
                                BorderBrush="#CE93D8" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <TextBlock Text="เลือกแล้ว" FontSize="12" Foreground="#7B1FA2"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="SelectedReservationInfo" FontSize="14"
                                           Foreground="#333" TextWrapping="Wrap"/>

                                <!-- Court Selection -->
                                <StackPanel Spacing="5">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon Glyph="&#xE707;" FontSize="13" Foreground="#4A148C"/>
                                        <TextBlock Text="สนามที่เข้าใช้งาน" FontSize="14"
                                                   FontWeight="SemiBold" Foreground="#333"/>
                                        <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                                    </StackPanel>
                                    <ComboBox x:Name="ReservationCourtComboBox"
                                              HorizontalAlignment="Stretch" Height="40"
                                              Background="White" BorderBrush="#E0E0E0"
                                              CornerRadius="6" PlaceholderText="เลือกสนาม"
                                              FontSize="14"/>
                                </StackPanel>

                                <!-- Check-in Button -->
                                <Button Click="BtnCheckinFromReservation_Click"
                                        Background="#4A148C" Foreground="White"
                                        HorizontalAlignment="Stretch" Height="44"
                                        CornerRadius="8" FontSize="15">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="White"/>
                                        <TextBlock Text="เช็คอินเข้าสนาม" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Mode: Walk-in ──────────────────── -->
                    <Border x:Name="WalkInModePanel" Visibility="Collapsed"
                            Background="White" CornerRadius="10"
                            Padding="16,14" BorderBrush="#E8E8E8" BorderThickness="1">
                        <StackPanel Spacing="14">

                            <!-- Row 1: สนาม + จุดประสงค์ -->
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="5">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE707;" FontSize="13" Foreground="#4A148C" Margin="0,0,6,0"/>
                                        <TextBlock Text="สนาม" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                                    </StackPanel>
                                    <ComboBox x:Name="WalkInCourtComboBox"
                                              HorizontalAlignment="Stretch" Height="40"
                                              Background="White" BorderBrush="#E0E0E0"
                                              CornerRadius="6" PlaceholderText="เลือกสนาม"
                                              FontSize="14"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="5">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE8CB;" FontSize="13" Foreground="#4A148C" Margin="0,0,6,0"/>
                                        <TextBlock Text="จุดประสงค์" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                                    </StackPanel>
                                    <ComboBox x:Name="WalkInTypeComboBox"
                                              HorizontalAlignment="Stretch" Height="40"
                                              Background="White" BorderBrush="#E0E0E0"
                                              CornerRadius="6" FontSize="14"
                                              SelectionChanged="WalkInTypeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="เช่าสนาม" Tag="Paid" IsSelected="True"/>
                                        <ComboBoxItem Content="คอร์สเรียน" Tag="Course"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Course (show only when Course) -->
                            <StackPanel x:Name="WalkInCoursePanel" Spacing="5" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE82D;" FontSize="13" Foreground="#7B1FA2" Margin="0,0,6,0"/>
                                    <TextBlock Text="คอร์สเรียน" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBox x:Name="WalkInCourseSearchBox"
                                         PlaceholderText="ค้นหาคอร์ส / รหัส / โค้ช..."
                                         Background="White" Height="36"
                                         BorderBrush="#E0E0E0" CornerRadius="6"
                                         FontSize="13" VerticalContentAlignment="Center"
                                         TextChanged="WalkInCourseSearchBox_TextChanged"/>
                                <ListView x:Name="WalkInCourseListView"
                                          MaxHeight="140"
                                          SelectionMode="Single"
                                          SelectionChanged="WalkInCourseListView_SelectionChanged">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,4"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                </ListView>
                            </StackPanel>

                            <!-- Row 2: เวลา + เวลาสิ้นสุด -->
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="5">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE823;" FontSize="13" Foreground="#4A148C" Margin="0,0,6,0"/>
                                        <TextBlock Text="เวลาเริ่ม" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                                    </StackPanel>
                                    <ComboBox x:Name="WalkInTimeComboBox"
                                              HorizontalAlignment="Stretch" Height="40"
                                              Background="White" BorderBrush="#E0E0E0"
                                              CornerRadius="6" PlaceholderText="เลือกเวลา"
                                              FontSize="14"
                                              SelectionChanged="WalkInStartTime_Changed">
                                        <ComboBoxItem Content="06:00" Tag="06:00"/>
                                        <ComboBoxItem Content="07:00" Tag="07:00"/>
                                        <ComboBoxItem Content="08:00" Tag="08:00"/>
                                        <ComboBoxItem Content="09:00" Tag="09:00"/>
                                        <ComboBoxItem Content="10:00" Tag="10:00"/>
                                        <ComboBoxItem Content="11:00" Tag="11:00"/>
                                        <ComboBoxItem Content="12:00" Tag="12:00"/>
                                        <ComboBoxItem Content="13:00" Tag="13:00"/>
                                        <ComboBoxItem Content="14:00" Tag="14:00"/>
                                        <ComboBoxItem Content="15:00" Tag="15:00"/>
                                        <ComboBoxItem Content="16:00" Tag="16:00"/>
                                        <ComboBoxItem Content="17:00" Tag="17:00"/>
                                        <ComboBoxItem Content="18:00" Tag="18:00"/>
                                        <ComboBoxItem Content="19:00" Tag="19:00"/>
                                        <ComboBoxItem Content="20:00" Tag="20:00"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="5">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE916;" FontSize="13" Foreground="#4A148C" Margin="0,0,6,0"/>
                                        <TextBlock Text="เวลาสิ้นสุด" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                                    </StackPanel>
                                    <ComboBox x:Name="WalkInEndTimeComboBox"
                                              HorizontalAlignment="Stretch" Height="40"
                                              Background="White" BorderBrush="#E0E0E0"
                                              CornerRadius="6" PlaceholderText="เลือกเวลาสิ้นสุด"
                                              FontSize="14"
                                              SelectionChanged="WalkInEndTime_Changed"/>
                                </StackPanel>
                            </Grid>

                            <!-- End Time Preview -->
                            <Border x:Name="WalkInEndTimePanel" Background="#F3E5F5" CornerRadius="6"
                                    Padding="12,8" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE76C;" FontSize="12" Foreground="#7B1FA2"/>
                                    <TextBlock x:Name="WalkInEndTimePreviewText" FontSize="13"
                                               Foreground="#4A148C" FontWeight="SemiBold"
                                               Text="--:-- → --:-- (0.0 ชม.)"/>
                                </StackPanel>
                            </Border>

                            <!-- Divider -->
                            <Border Background="#F0F0F0" Height="1"/>

                            <!-- ชื่อ -->
                            <StackPanel Spacing="5">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE77B;" FontSize="13" Foreground="#4A148C" Margin="0,0,6,0"/>
                                    <TextBlock Text="ชื่อผู้ใช้งาน" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBox x:Name="WalkInNameTextBox"
                                         PlaceholderText="กรอกชื่อผู้ใช้งาน"
                                         Background="White" Height="40"
                                         BorderBrush="#E0E0E0" CornerRadius="6"
                                         FontSize="14" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- เบอร์โทร -->
                            <StackPanel Spacing="5">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE717;" FontSize="13" Foreground="#999" Margin="0,0,6,0"/>
                                    <TextBlock Text="เบอร์โทรศัพท์" FontSize="14" Foreground="#666"/>
                                </StackPanel>
                                <TextBox x:Name="WalkInPhoneTextBox"
                                         PlaceholderText="0812345678"
                                         Background="White" Height="40"
                                         BorderBrush="#E0E0E0" CornerRadius="6"
                                         FontSize="14" MaxLength="10"
                                         InputScope="TelephoneNumber"
                                         VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Buttons -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="12">
                                <Button Click="BtnClearWalkIn_Click"
                                        Background="White" Foreground="#424242"
                                        BorderBrush="#E0E0E0" BorderThickness="1"
                                        Height="44" Padding="28,0"
                                        CornerRadius="8" FontSize="14"
                                        Content="ยกเลิก"/>
                                <Button Click="BtnCheckinWalkIn_Click"
                                        Background="#4A148C" Foreground="White"
                                        Height="44" Padding="28,0"
                                        CornerRadius="8" FontSize="14"
                                        BorderThickness="0">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="White"/>
                                        <TextBlock Text="เช็คอิน" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <!-- Keyboard spacer -->
                    <Border x:Name="KeyboardSpacer" Height="0" Background="Transparent"/>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Page>
