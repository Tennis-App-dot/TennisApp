<Page
    x:Class="TennisApp.Presentation.Pages.TraineePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TennisApp.Presentation.Pages"
    xmlns:dialogs="using:TennisApp.Presentation.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <Grid x:Name="RootGrid" Padding="20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Visual State Manager for Responsive Design -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowSizeStates">
                <!-- Narrow (Phone/Small Tablet Portrait - < 720px) -->
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="16,16"/>
                        <Setter Target="HeaderText.FontSize" Value="24"/>
                        <Setter Target="SearchGrid.Margin" Value="0,0,0,16"/>
                        <Setter Target="FilterComboBox.Width" Value="Auto"/>
                        <Setter Target="SearchTextBox.Width" Value="*"/>
                        <Setter Target="AddButton.Padding" Value="16,10"/>
                        <Setter Target="AddButton.FontSize" Value="14"/>
                        
                        <!-- Hide some columns on narrow screens -->
                        <Setter Target="ColHeaderID.Width" Value="120"/>
                        <Setter Target="ColHeaderFirstName.Width" Value="100"/>
                        <Setter Target="ColHeaderLastName.Width" Value="0"/>
                        <Setter Target="ColHeaderPhone.Width" Value="130"/>
                        <Setter Target="ColHeaderEdit.Width" Value="60"/>
                        <Setter Target="ColHeaderDelete.Width" Value="60"/>
                    </VisualState.Setters>
                </VisualState>

                <!-- Medium (Tablet - 720px to 1024px) -->
                <VisualState x:Name="MediumState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="720"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="24,20"/>
                        <Setter Target="HeaderText.FontSize" Value="28"/>
                        <Setter Target="ColHeaderID.Width" Value="1.5*"/>
                        <Setter Target="ColHeaderFirstName.Width" Value="1.5*"/>
                        <Setter Target="ColHeaderLastName.Width" Value="2*"/>
                        <Setter Target="ColHeaderPhone.Width" Value="1.5*"/>
                        <Setter Target="ColHeaderEdit.Width" Value="*"/>
                        <Setter Target="ColHeaderDelete.Width" Value="*"/>
                    </VisualState.Setters>
                </VisualState>

                <!-- Wide (Desktop/Large Tablet - > 1024px) -->
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1024"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="40,20"/>
                        <Setter Target="HeaderText.FontSize" Value="32"/>
                        <Setter Target="ColHeaderID.Width" Value="1.5*"/>
                        <Setter Target="ColHeaderFirstName.Width" Value="1.5*"/>
                        <Setter Target="ColHeaderLastName.Width" Value="2*"/>
                        <Setter Target="ColHeaderPhone.Width" Value="1.5*"/>
                        <Setter Target="ColHeaderEdit.Width" Value="*"/>
                        <Setter Target="ColHeaderDelete.Width" Value="*"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Header -->
        <TextBlock x:Name="HeaderText"
                   Grid.Row="0" 
                   Text="ผู้เรียน" 
                   FontSize="32" 
                   FontWeight="Bold"
                   Margin="0,0,0,24"
                   VerticalAlignment="Center"/>

        <!-- Search Bar with Add Button -->
        <Grid x:Name="SearchGrid" 
              Grid.Row="1" 
              Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Filter Dropdown -->
            <ComboBox x:Name="FilterComboBox"
                      Grid.Column="0"
                      ItemsSource="{x:Bind ViewModel.SearchFields, Mode=OneTime}"
                      SelectedItem="{x:Bind ViewModel.SelectedSearchField, Mode=TwoWay}"
                      PlaceholderText="ค้นหาจาก"
                      Background="White"
                      Height="45"
                      MinWidth="150"
                      Margin="0,0,20,0"
                      VerticalAlignment="Center"/>

            <!-- Search TextBox with Button -->
            <Grid Grid.Column="1" Margin="0,0,20,0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="SearchTextBox"
                         Grid.Column="0"
                         Text="{x:Bind ViewModel.SearchKeyword, Mode=TwoWay}"
                         PlaceholderText="ค้นหา..."
                         Background="White"
                         Height="45"
                         VerticalContentAlignment="Center"
                         FontSize="16"
                         BorderThickness="1"
                         BorderBrush="#E0E0E0"
                         CornerRadius="4"
                         KeyDown="SearchTextBox_KeyDown"/>

                <Button Grid.Column="1"
                        Command="{x:Bind ViewModel.SearchCommand}"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        Height="45"
                        Width="50"
                        CornerRadius="4"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                    <FontIcon Glyph="&#xE721;" FontSize="18" Foreground="#666666"/>
                </Button>
            </Grid>

            <!-- Add Button -->
            <Button x:Name="AddButton"
                    Grid.Column="2"
                    Content="สร้างทะเบียนประวัติ"
                    Background="#4A148C"
                    Foreground="White"
                    FontSize="16"
                    Height="45"
                    Padding="24,10"
                    CornerRadius="4"
                    Click="BtnAddTrainee_Click"/>
        </Grid>

        <!-- Data Table with Responsive Columns -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="8"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Grid x:Name="TableHeader"
                      Grid.Row="0" 
                      Background="#00E676" 
                      MinHeight="50"
                      Padding="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="ColHeaderID" Width="1.5*"/>
                        <ColumnDefinition x:Name="ColHeaderFirstName" Width="1.5*"/>
                        <ColumnDefinition x:Name="ColHeaderLastName" Width="2*"/>
                        <ColumnDefinition x:Name="ColHeaderPhone" Width="1.5*"/>
                        <ColumnDefinition x:Name="ColHeaderEdit" Width="*" MinWidth="60"/>
                        <ColumnDefinition x:Name="ColHeaderDelete" Width="*" MinWidth="60"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="รหัสประจำตัวผู้เรียน" 
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="0,8"/>
                    
                    <TextBlock Grid.Column="1" 
                               Text="ชื่อ" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="2" 
                               Text="นามสกุล" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="3" 
                               Text="เบอร์โทรศัพท์" 
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="0,8"/>
                    
                    <TextBlock Grid.Column="4" 
                               Text="แก้ไข" 
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="5" 
                               Text="ลบ" 
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Table Body with ListView -->
                <Grid Grid.Row="1">
                    <!-- Loading Indicator -->
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Width="50"
                                  Height="50"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>

                    <!-- No Results Message -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="12"
                                Visibility="{x:Bind ViewModel.HasNoResults, Mode=OneWay}">
                        <FontIcon Glyph="&#xE11A;" FontSize="48" Foreground="#999"/>
                        <TextBlock Text="ไม่พบข้อมูล"
                                   FontSize="18"
                                   Foreground="#666"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Data List -->
                    <ListView x:Name="TraineesListView"
                              ItemsSource="{x:Bind ViewModel.Trainees, Mode=OneWay}"
                              SelectionMode="None"
                              Visibility="{x:Bind ViewModel.HasNoResults, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="50" 
                                      Padding="16,8" 
                                      Background="White"
                                      Tapped="TraineeRow_Tapped">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="*" MinWidth="60"/>
                                        <ColumnDefinition Width="*" MinWidth="60"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding TraineeId}"
                                               VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding FirstName}"
                                               VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="2" 
                                               Text="{Binding LastName}"
                                               VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="3" 
                                               Text="{Binding Phone}"
                                               VerticalAlignment="Center"/>
                                    
                                    <Button Grid.Column="4" 
                                            Background="Transparent"
                                            HorizontalAlignment="Center"
                                            Click="BtnEditTrainee_Click"
                                            Tapped="Button_Tapped"
                                            Tag="{Binding TraineeId}">
                                        <FontIcon Glyph="&#xE70F;" Foreground="#FFA726" FontSize="18"/>
                                    </Button>
                                    
                                    <Button Grid.Column="5" 
                                            Background="Transparent"
                                            HorizontalAlignment="Center"
                                            Click="BtnDeleteTrainee_Click"
                                            Tapped="Button_Tapped"
                                            Tag="{Binding TraineeId}">
                                        <FontIcon Glyph="&#xE74D;" Foreground="#EF5350" FontSize="18"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Load More Button -->
                <Button Grid.Row="2"
                        Command="{x:Bind ViewModel.LoadMoreCommand}"
                        Content="โหลดเพิ่มเติม..."
                        HorizontalAlignment="Center"
                        Margin="0,16"
                        Padding="32,12"
                        Background="#4A148C"
                        Foreground="White"
                        CornerRadius="4"
                        Visibility="{x:Bind ViewModel.HasMoreData, Mode=OneWay}"/>
            </Grid>
        </Border>

        <!-- Detail Card Overlay -->
        <Grid x:Name="DetailOverlay" 
              Grid.RowSpan="3"
              Background="Transparent"
              Visibility="Collapsed"
              Tapped="DetailOverlay_Tapped">
            <dialogs:TraineeDetailCard x:Name="DetailCard"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Page>
