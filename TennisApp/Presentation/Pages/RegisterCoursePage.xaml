<Page
    x:Class="TennisApp.Presentation.Pages.RegisterCoursePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5"
    FontFamily="ms-appx:///Assets/Fonts/NotoSansThai-Regular.ttf#Noto Sans Thai">

    <Grid Padding="40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Header ══════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="รายการสมัครคอร์สเรียน"
                       FontSize="32" FontWeight="Bold"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    x:Name="BtnNewRegister"
                    Content="+ สมัครคอร์สใหม่"
                    Background="#4A148C" Foreground="White"
                    FontSize="16" Height="45"
                    Padding="24,0" CornerRadius="4"
                    Click="BtnNewRegister_Click"/>
        </Grid>

        <!-- ══ Search Bar ══════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="0,0,0,16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtSearch"
                     Grid.Column="0"
                     PlaceholderText="ค้นหาชื่อผู้เรียน, รหัสคอร์ส, ชื่อคอร์ส, ผู้สอน..."
                     Background="White" Height="45"
                     VerticalContentAlignment="Center"
                     FontSize="15" CornerRadius="4"
                     BorderBrush="#E0E0E0" BorderThickness="1"
                     TextChanged="SearchBox_TextChanged"/>

            <Button Grid.Column="1"
                    Background="White" BorderBrush="#E0E0E0"
                    BorderThickness="1" Height="45" Width="50"
                    CornerRadius="4" Click="BtnSearch_Click">
                <FontIcon Glyph="&#xE721;" FontSize="18" Foreground="#666"/>
            </Button>
        </Grid>

        <!-- ══ Table ═══════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <ScrollViewer HorizontalScrollMode="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled">
                <Grid MinWidth="950">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Table Header -->
                    <Grid Grid.Row="0" Background="#00E676"
                          MinHeight="48" Padding="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="#"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="วันที่สมัคร"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="รหัสผู้เรียน"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="ชื่อผู้เรียน"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="คอร์ส"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="ชื่อคอร์ส"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="ผู้สอน"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="7" Text="ลบ"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Loading -->
                    <ProgressRing Grid.Row="1"
                                  x:Name="LoadingRing"
                                  IsActive="False"
                                  Width="40" Height="40"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>

                    <!-- Empty -->
                    <StackPanel x:Name="EmptyPanel"
                                Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8" Margin="0,40"
                                Visibility="Collapsed">
                        <FontIcon Glyph="&#xE8A5;" FontSize="48" Foreground="#BDBDBD"/>
                        <TextBlock Text="ยังไม่มีรายการสมัคร"
                                   FontSize="16" Foreground="#9E9E9E"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Data List -->
                    <ListView x:Name="RegisListView"
                              Grid.Row="1"
                              SelectionMode="None"
                              Visibility="Collapsed">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="46" Padding="16,4"
                                      BorderBrush="#F0F0F0"
                                      BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding RowNumber}"
                                               FontSize="13" Foreground="#9E9E9E"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding RegisDateFormatted}"
                                               FontSize="13" Foreground="#424242"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TraineeId}"
                                               FontSize="13"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding TraineeName}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Border Grid.Column="4"
                                            Background="#E3F2FD"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ClassId}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#1565C0"/>
                                    </Border>
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding ClassName}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="6"
                                                Orientation="Horizontal"
                                                Spacing="4"
                                                VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE77B;"
                                                  FontSize="13" Foreground="#757575"/>
                                        <TextBlock Text="{Binding TrainerDisplayName}"
                                                   FontSize="13" Foreground="#616161"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Button Grid.Column="7"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Width="34" Height="34" Padding="0"
                                            HorizontalAlignment="Center"
                                            Click="BtnDeleteRegis_Click"
                                            Tag="{Binding}">
                                        <FontIcon Glyph="&#xE74D;"
                                                  Foreground="#EF5350" FontSize="15"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
