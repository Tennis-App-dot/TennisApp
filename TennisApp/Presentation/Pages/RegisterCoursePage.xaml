<Page
    x:Class="TennisApp.Presentation.Pages.RegisterCoursePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TennisApp.Presentation.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <Grid Padding="40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="สมัครคอร์สเรียน" 
                   FontSize="32" 
                   FontWeight="Bold"
                   Margin="0,0,0,24"/>

        <!-- Search Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Filter Dropdown -->
            <ComboBox x:Name="FilterComboBox"
                      Grid.Column="0"
                      ItemsSource="{x:Bind ViewModel.FilterFields, Mode=OneTime}"
                      SelectedItem="{x:Bind ViewModel.SelectedFilterField, Mode=TwoWay}"
                      PlaceholderText="ค้นหาจาก"
                      Background="White"
                      Height="45"
                      MinWidth="150"
                      Margin="0,0,20,0"
                      VerticalAlignment="Center"/>

            <!-- Search TextBox with Button -->
            <Grid Grid.Column="1" Margin="0,0,0,0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="SearchTextBox"
                         Grid.Column="0"
                         Text="{x:Bind ViewModel.SearchKeyword, Mode=TwoWay}"
                         PlaceholderText="ค้นหา..."
                         Background="White"
                         Height="45"
                         VerticalContentAlignment="Center"
                         FontSize="16"
                         BorderThickness="1"
                         BorderBrush="#E0E0E0"
                         CornerRadius="4"
                         KeyDown="SearchTextBox_KeyDown"/>

                <Button Grid.Column="1"
                        Click="BtnSearch_Click"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        Height="45"
                        Width="50"
                        CornerRadius="4"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                    <FontIcon Glyph="&#xE721;" FontSize="18" Foreground="#666666"/>
                </Button>
            </Grid>
        </Grid>

        <!-- Data Table -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="8"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Grid Grid.Row="0" 
                      Background="#00E676" 
                      MinHeight="50"
                      Padding="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="*" MinWidth="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="รหัสประจำตัวผู้เรียน" 
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="0,8"/>
                    
                    <TextBlock Grid.Column="1" 
                               Text="ชื่อ" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="2" 
                               Text="นามสกุล" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="3" 
                               Text="เบอร์โทรศัพท์" 
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="0,8"/>
                    
                    <TextBlock Grid.Column="4" 
                               Text="สมัครคอร์สเรียน" 
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Table Body -->
                <Grid Grid.Row="1">
                    <!-- Loading Indicator -->
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Width="50"
                                  Height="50"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>

                    <!-- No Results Message -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="12"
                                Visibility="{x:Bind ViewModel.HasNoResults, Mode=OneWay}">
                        <FontIcon Glyph="&#xE11A;" FontSize="48" Foreground="#999"/>
                        <TextBlock Text="ไม่พบข้อมูล"
                                   FontSize="18"
                                   Foreground="#666"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Data List -->
                    <ListView x:Name="TraineesListView"
                              ItemsSource="{x:Bind ViewModel.Trainees, Mode=OneWay}"
                              SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="50" 
                                      Padding="16,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="*" MinWidth="100"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding TraineeId}"
                                               VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding FirstName}"
                                               VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="2" 
                                               Text="{Binding LastName}"
                                               VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="3" 
                                               Text="{Binding Phone}"
                                               VerticalAlignment="Center"/>
                                    
                                    <Button Grid.Column="4" 
                                            Background="Transparent"
                                            HorizontalAlignment="Center"
                                            Width="40"
                                            Height="40"
                                            BorderThickness="0"
                                            Click="BtnRegister_Click"
                                            Tag="{Binding TraineeId}"
                                            ToolTipService.ToolTip="สมัครเรียน">
                                        <FontIcon Glyph="&#xE70F;" 
                                                  FontSize="20" 
                                                  Foreground="Black"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
