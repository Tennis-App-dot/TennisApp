<Page
    x:Class="TennisApp.Presentation.Pages.RegisterCoursePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F2F4F7">

    <Grid x:Name="RootGrid" Padding="16,14">

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowSizeStates">
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="12,10"/>
                        <Setter Target="HeaderTitle.FontSize" Value="22"/>
                        <Setter Target="AddButton.Height" Value="44"/>
                        <Setter Target="AddButton.Padding" Value="16,0"/>
                        <Setter Target="AddButtonText.FontSize" Value="14"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="600"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="24,18"/>
                        <Setter Target="HeaderTitle.FontSize" Value="26"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="HeaderTitle"
                       Text="รายการสมัครคอร์สเรียน"
                       FontSize="26" FontWeight="ExtraBold"
                       Foreground="#1A1A2E"
                       VerticalAlignment="Center"/>

            <Button x:Name="AddButton" Grid.Column="1"
                    Click="BtnNewRegister_Click"
                    Background="#6C2BD9" Foreground="White"
                    Height="52" FontSize="16" FontWeight="Bold"
                    Padding="28,0" CornerRadius="14"
                    BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE710;" FontSize="18"/>
                    <TextBlock x:Name="AddButtonText"
                               Text="สมัครคอร์สใหม่" VerticalAlignment="Center"
                               FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ── Search Bar ─────────────────────────────────── -->
        <StackPanel Grid.Row="1" Spacing="8" Margin="0,0,0,14">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtSearch"
                         Grid.Column="0"
                         PlaceholderText="ค้นหาชื่อผู้เรียน, รหัสคอร์ส, ชื่อคอร์ส, ผู้สอน..."
                         Background="White"
                         Height="44"
                         VerticalContentAlignment="Center"
                         FontSize="15"
                         BorderThickness="1"
                         BorderBrush="#E5E7EB"
                         CornerRadius="10"
                         TextChanged="SearchBox_TextChanged"/>

                <Button Grid.Column="1"
                        Click="BtnSearch_Click"
                        Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Height="44" Width="48"
                        CornerRadius="10">
                    <FontIcon Glyph="&#xE721;" FontSize="18" Foreground="#6B7280"/>
                </Button>
            </Grid>
        </StackPanel>

        <!-- ── Registration Card List ─────────────────────── -->
        <Grid Grid.Row="2">
            <!-- Loading -->
            <ProgressRing x:Name="LoadingRing"
                          IsActive="False"
                          Width="50" Height="50"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyPanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12"
                        Visibility="Collapsed">
                <FontIcon Glyph="&#xE8A5;" FontSize="64" Foreground="#D1D5DB"/>
                <TextBlock Text="ยังไม่มีรายการสมัคร"
                           FontSize="18" Foreground="#9CA3AF"
                           HorizontalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text="กดปุ่ม &quot;สมัครคอร์สใหม่&quot; เพื่อเริ่มต้น"
                           FontSize="14" Foreground="#D1D5DB"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Card ListView -->
            <ListView x:Name="RegisListView"
                      SelectionMode="None"
                      Visibility="Collapsed">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,12"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White"
                                CornerRadius="14"
                                Padding="0"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                MinHeight="90">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Course Badge (left) -->
                                <Border Grid.Column="0"
                                        Width="72" Height="72"
                                        CornerRadius="14"
                                        Background="#EDE7F6"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center">
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Spacing="2">
                                        <TextBlock Text="{Binding ClassId}"
                                                   FontSize="16" FontWeight="ExtraBold"
                                                   Foreground="#6C2BD9"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ClassTimeText}"
                                                   FontSize="10" Foreground="#9575CD"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Info (center) -->
                                <StackPanel Grid.Column="1"
                                            Spacing="4"
                                            Padding="16,14"
                                            VerticalAlignment="Center">
                                    <!-- ชื่อผู้เรียน -->
                                    <TextBlock Text="{Binding TraineeName}"
                                               FontSize="17" FontWeight="Bold"
                                               Foreground="#1A1A2E"
                                               TextTrimming="CharacterEllipsis"/>
                                    <!-- รหัสผู้เรียน + วันที่สมัคร -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding TraineeId}"
                                                   FontSize="13" Foreground="#6B7280"/>
                                        <TextBlock Text="•"
                                                   FontSize="13" Foreground="#D1D5DB"/>
                                        <TextBlock Text="{Binding RegisDateFormatted}"
                                                   FontSize="13" Foreground="#6B7280"/>
                                    </StackPanel>
                                    <!-- ชื่อคอร์ส -->
                                    <TextBlock Text="{Binding ClassName}"
                                               FontSize="14" Foreground="#4B5563"
                                               TextTrimming="CharacterEllipsis"/>
                                    <!-- ผู้สอน -->
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE77B;" FontSize="13" Foreground="#9CA3AF"/>
                                        <TextBlock Text="{Binding TrainerDisplayName}"
                                                   FontSize="14" Foreground="#6B7280"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Delete Button (right) -->
                                <Button Grid.Column="2"
                                        Background="#FEF2F2"
                                        Foreground="#DC2626"
                                        CornerRadius="12"
                                        Width="44" Height="44"
                                        Padding="0"
                                        BorderThickness="0"
                                        VerticalAlignment="Center"
                                        Margin="0,0,12,0"
                                        Click="BtnDeleteRegis_Click"
                                        Tag="{Binding}"
                                        ToolTipService.ToolTip="ลบ">
                                    <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
