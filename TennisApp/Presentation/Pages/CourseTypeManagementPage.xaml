<Page
    x:Class="TennisApp.Presentation.Pages.CourseTypeManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F2F4F7">

    <Grid Padding="16,14,16,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Click="BtnBack_Click"
                    Background="Transparent" BorderThickness="0"
                    Height="44" Width="44" Padding="0" CornerRadius="10"
                    VerticalAlignment="Center">
                <FontIcon Glyph="&#xE72B;" FontSize="20" Foreground="#6B7280"/>
            </Button>

            <TextBlock Grid.Column="1" Text="จัดการรูปแบบคอร์ส"
                       FontSize="24" FontWeight="ExtraBold" Foreground="#1A1A2E"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>

            <Button x:Name="BtnAddType" Click="BtnAddType_Click" Grid.Column="2"
                    Background="#6C2BD9" Foreground="White"
                    Height="48" Padding="20,0" CornerRadius="12" BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="16"/>
                    <TextBlock Text="เพิ่มประเภทคอร์ส" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ── Search Bar ──────────────────────────── -->
        <Grid Grid.Row="1" ColumnSpacing="8" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchTextBox"
                     Grid.Column="0"
                     PlaceholderText="ค้นหารหัส, ชื่อประเภทคอร์ส..."
                     Background="White"
                     Height="44"
                     VerticalContentAlignment="Center"
                     FontSize="15"
                     BorderThickness="1"
                     BorderBrush="#E5E7EB"
                     CornerRadius="10"
                     TextChanged="SearchTextBox_TextChanged"/>

            <Button Grid.Column="1"
                    Click="BtnSearch_Click"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Height="44" Width="48"
                    CornerRadius="10">
                <FontIcon Glyph="&#xE721;" FontSize="18" Foreground="#6B7280"/>
            </Button>
        </Grid>

        <!-- ── Content ─────────────────────────────── -->
        <Grid Grid.Row="2">
            <!-- Scrollable card list -->
            <ScrollViewer x:Name="CardScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="CardContainer" Spacing="10" Padding="0,0,0,100"/>
            </ScrollViewer>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyPanel" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <FontIcon Glyph="&#xE82D;" FontSize="56" Foreground="#D1D5DB"/>
                <TextBlock x:Name="EmptyStateText" Text="ยังไม่มีประเภทคอร์ส" FontSize="18" Foreground="#9CA3AF"
                           HorizontalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text="กดปุ่ม &quot;เพิ่มประเภทคอร์ส&quot; เพื่อเริ่มต้น"
                           FontSize="14" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
