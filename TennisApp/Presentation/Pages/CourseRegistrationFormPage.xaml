<Page
    x:Class="TennisApp.Presentation.Pages.CourseRegistrationFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5"
    FontFamily="ms-appx:///Assets/Fonts/NotoSansThai-Regular.ttf#Noto Sans Thai">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Padding="40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Header ══════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Background="Transparent" BorderThickness="0"
                    Padding="0,0,12,0" Click="BtnBack_Click"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE76B;" FontSize="18" Foreground="#424242"/>
                    <TextBlock Text="กลับ" FontSize="15" Foreground="#424242"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock Grid.Column="1"
                       Text="สมัครคอร์สเรียน"
                       FontSize="28" FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
        </Grid>

        <!-- ══ Section 1: เลือกคอร์ส (Card Grid) ═══════════════ -->
        <Border Grid.Row="1"
                Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1"
                Padding="32,24" Margin="0,0,0,20">
            <StackPanel Spacing="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal" Spacing="10">
                        <Border Background="#4A148C" CornerRadius="14" Width="28" Height="28">
                            <TextBlock Text="1" FontSize="14" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="เลือกคอร์ส"
                                   FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Column="2" ColumnSpacing="8" MinWidth="280">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtCourseSearch"
                                 PlaceholderText="ค้นหาคอร์ส..."
                                 Background="White" Height="38"
                                 VerticalContentAlignment="Center"
                                 FontSize="14" CornerRadius="4"
                                 BorderBrush="#E0E0E0" BorderThickness="1"
                                 TextChanged="TxtCourseSearch_TextChanged"/>
                        <Button Grid.Column="1"
                                Background="White" BorderBrush="#E0E0E0"
                                BorderThickness="1" Height="38" Width="38"
                                CornerRadius="4"
                                Click="BtnCourseSearch_Click">
                            <FontIcon Glyph="&#xE721;" FontSize="14" Foreground="#666"/>
                        </Button>
                    </Grid>
                </Grid>

                <Border Background="#F5F5F5" Height="1"/>

                <ScrollViewer HorizontalScrollMode="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollMode="Disabled"
                              Padding="0,4">
                    <StackPanel x:Name="CourseCardsPanel"
                                Orientation="Horizontal"
                                Spacing="12"/>
                </ScrollViewer>

                <TextBlock x:Name="TxtNoCourses"
                           Text="ไม่พบคอร์ส"
                           FontSize="14" Foreground="#9E9E9E"
                           HorizontalAlignment="Center"
                           Visibility="Collapsed"/>

                <Border x:Name="CourseDetailsPanel"
                        Background="#F3E5F5" CornerRadius="8"
                        Padding="20" Visibility="Collapsed">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto" MinWidth="220"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="TxtSelectedCourseId"
                                       FontSize="12" Foreground="#7B1FA2"/>
                            <TextBlock x:Name="TxtCourseName"
                                       FontSize="16" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE77B;" FontSize="14" Foreground="#616161"/>
                                <TextBlock x:Name="TxtCourseTrainer"
                                           FontSize="14" Foreground="#616161"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="เลือกแพ็กเกจ" FontSize="14"/>
                                <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                            </StackPanel>
                            <ComboBox x:Name="CmbPackage"
                                      PlaceholderText="เลือกจำนวนครั้ง"
                                      Background="White" Height="42"
                                      HorizontalAlignment="Stretch" FontSize="14"
                                      BorderBrush="#E0E0E0"
                                      SelectionChanged="CmbPackage_SelectionChanged"/>
                            <TextBlock x:Name="TxtPackagePrice"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="#D32F2F"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══ Section 2: ผู้สมัคร ════════════════════════════ -->
        <Border Grid.Row="2"
                Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1"
                Padding="32,24" Margin="0,0,0,20">
            <StackPanel Spacing="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal" Spacing="10">
                        <Border Background="#4A148C" CornerRadius="14" Width="28" Height="28">
                            <TextBlock Text="2" FontSize="14" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ผู้สมัคร"
                                   FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="BtnAddTrainee"
                            Grid.Column="2"
                            Content="+ เพิ่มผู้สมัคร"
                            Background="#4A148C" Foreground="White"
                            FontSize="14" Height="38"
                            Padding="20,0" CornerRadius="4"
                            IsEnabled="False"
                            Click="BtnAddTrainee_Click"/>
                </Grid>

                <Border Background="#F5F5F5" Height="1" Margin="0,0,0,4"/>

                <Border Background="White" CornerRadius="6"
                        BorderBrush="#E0E0E0" BorderThickness="1"
                        MinHeight="120">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Background="#00E676"
                              MinHeight="40" Padding="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="#"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="รหัสผู้เรียน"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="ชื่อ-นามสกุล"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="ชื่อเล่น"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="ลบ"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Grid>

                        <StackPanel x:Name="EmptyTraineePanel"
                                    Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8" Margin="0,24">
                            <FontIcon Glyph="&#xE77B;" FontSize="36" Foreground="#BDBDBD"/>
                            <TextBlock Text="ยังไม่มีผู้สมัครในรายการ"
                                       FontSize="15" Foreground="#9E9E9E"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <ListView x:Name="SelectedTraineesListView"
                                  Grid.Row="1"
                                  SelectionMode="None"
                                  Visibility="Collapsed">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="44" Padding="16,4"
                                          Background="White"
                                          BorderBrush="#F0F0F0"
                                          BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Index}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TraineeId}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding FullName}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Nickname}"
                                                   FontSize="13" Foreground="#616161"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="4"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Width="34" Height="34" Padding="0"
                                                HorizontalAlignment="Center"
                                                Click="BtnRemoveTrainee_Click"
                                                Tag="{Binding TraineeId}">
                                            <FontIcon Glyph="&#xE74D;"
                                                      Foreground="#EF5350" FontSize="15"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══ Section 3: สรุป ═════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1"
                Padding="32,20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4"
                            HorizontalAlignment="Center">
                    <TextBlock Text="จำนวนผู้สมัคร"
                               FontSize="13" Foreground="#9E9E9E"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTraineeCount"
                               Text="0 คน"
                               FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="4"
                            HorizontalAlignment="Center">
                    <TextBlock Text="ราคาต่อคน"
                               FontSize="13" Foreground="#9E9E9E"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtPricePerPerson"
                               Text="฿0"
                               FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="4"
                            HorizontalAlignment="Center">
                    <TextBlock Text="รวมทั้งหมด"
                               FontSize="13" Foreground="#9E9E9E"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalPrice"
                               Text="฿0"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#D32F2F"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Buttons ═════════════════════════════════════════ -->
        <Grid Grid.Row="4" Margin="0,0,0,40">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="16">
                <Button x:Name="BtnCancel"
                        Content="ยกเลิก"
                        Background="White" Foreground="#424242"
                        BorderBrush="#E0E0E0" BorderThickness="1"
                        FontSize="16" Height="46"
                        Padding="32,0" CornerRadius="6"
                        Click="BtnBack_Click"/>
                <Button x:Name="BtnConfirm"
                        Content="ยืนยันการสมัคร"
                        Background="#4A148C" Foreground="White"
                        FontSize="16" Height="46"
                        Padding="32,0" CornerRadius="6"
                        IsEnabled="False"
                        Click="BtnConfirm_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
    </ScrollViewer>
</Page>
