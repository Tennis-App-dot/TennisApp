<Page
    x:Class="TennisApp.Presentation.Pages.CourseRegistrationFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F2F4F7">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid x:Name="RootGrid" Padding="16,14">

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowSizeStates">
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="12,10"/>
                        <Setter Target="HeaderTitle.FontSize" Value="22"/>
                        <Setter Target="SummaryGrid.Padding" Value="16,16"/>
                        <Setter Target="ButtonsPanel.HorizontalAlignment" Value="Stretch"/>
                        <Setter Target="BtnCancel.HorizontalAlignment" Value="Stretch"/>
                        <Setter Target="BtnConfirm.HorizontalAlignment" Value="Stretch"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="600"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="24,18"/>
                        <Setter Target="HeaderTitle.FontSize" Value="26"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Header ══════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Background="Transparent" BorderThickness="0"
                    Padding="0,0,12,0" Click="BtnBack_Click"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE76B;" FontSize="18" Foreground="#1A1A2E"/>
                    <TextBlock Text="กลับ" FontSize="15" Foreground="#1A1A2E"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock x:Name="HeaderTitle"
                       Grid.Column="1"
                       Text="สมัครคอร์สเรียน"
                       FontSize="26" FontWeight="ExtraBold"
                       Foreground="#1A1A2E"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
        </Grid>

        <!-- ══ Section 1: เลือกคอร์ส (Card Grid) ═══════════════ -->
        <Border Grid.Row="1"
                Background="White" CornerRadius="14"
                BorderBrush="#E5E7EB" BorderThickness="1"
                Padding="20,16" Margin="0,0,0,14">
            <StackPanel Spacing="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal" Spacing="10">
                        <Border Background="#6C2BD9" CornerRadius="14" Width="28" Height="28">
                            <TextBlock Text="1" FontSize="14" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="เลือกคอร์ส"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="#1A1A2E"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Search -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtCourseSearch"
                             PlaceholderText="ค้นหาคอร์ส..."
                             Background="White" Height="40"
                             VerticalContentAlignment="Center"
                             FontSize="14" CornerRadius="10"
                             BorderBrush="#E5E7EB" BorderThickness="1"
                             TextChanged="TxtCourseSearch_TextChanged"/>
                    <Button Grid.Column="1"
                            Background="White" BorderBrush="#E5E7EB"
                            BorderThickness="1" Height="40" Width="40"
                            CornerRadius="10"
                            Click="BtnCourseSearch_Click">
                        <FontIcon Glyph="&#xE721;" FontSize="14" Foreground="#6B7280"/>
                    </Button>
                </Grid>

                <Border Background="#F2F4F7" Height="1"/>

                <ScrollViewer HorizontalScrollMode="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollMode="Disabled"
                              Padding="0,4">
                    <StackPanel x:Name="CourseCardsPanel"
                                Orientation="Horizontal"
                                Spacing="12"/>
                </ScrollViewer>

                <TextBlock x:Name="TxtNoCourses"
                           Text="ไม่พบคอร์ส"
                           FontSize="14" Foreground="#9CA3AF"
                           HorizontalAlignment="Center"
                           Visibility="Collapsed"/>

                <Border x:Name="CourseDetailsPanel"
                        Background="#EDE7F6" CornerRadius="10"
                        Padding="16" Visibility="Collapsed">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="TxtSelectedCourseId"
                                       FontSize="12" Foreground="#6C2BD9"/>
                            <TextBlock x:Name="TxtCourseName"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="#1A1A2E"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE77B;" FontSize="14" Foreground="#6B7280"/>
                                <TextBlock x:Name="TxtCourseTrainer"
                                           FontSize="14" Foreground="#6B7280"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="TxtSessionInfo"
                                       FontSize="14" Foreground="#6B7280"/>
                            <TextBlock x:Name="TxtPackagePrice"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#D32F2F"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══ Section 2: ผู้สมัคร ════════════════════════════ -->
        <Border Grid.Row="2"
                Background="White" CornerRadius="14"
                BorderBrush="#E5E7EB" BorderThickness="1"
                Padding="20,16" Margin="0,0,0,14">
            <StackPanel Spacing="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal" Spacing="10">
                        <Border Background="#6C2BD9" CornerRadius="14" Width="28" Height="28">
                            <TextBlock Text="2" FontSize="14" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ผู้สมัคร"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="#1A1A2E"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="BtnAddTrainee"
                            Grid.Column="2"
                            Background="#6C2BD9" Foreground="White"
                            FontSize="14" Height="38"
                            Padding="20,0" CornerRadius="10"
                            BorderThickness="0"
                            IsEnabled="False"
                            Click="BtnAddTrainee_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock Text="เพิ่มผู้สมัคร" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Background="#F2F4F7" Height="1"/>

                <Border Background="White" CornerRadius="10"
                        BorderBrush="#E5E7EB" BorderThickness="1"
                        MinHeight="120">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Background="#00E676"
                              MinHeight="40" Padding="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="#"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="รหัสผู้เรียน"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="ชื่อ-นามสกุล"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="ชื่อเล่น"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="ลบ"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Grid>

                        <StackPanel x:Name="EmptyTraineePanel"
                                    Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8" Margin="0,24">
                            <FontIcon Glyph="&#xE77B;" FontSize="36" Foreground="#D1D5DB"/>
                            <TextBlock Text="ยังไม่มีผู้สมัครในรายการ"
                                       FontSize="15" Foreground="#9CA3AF"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <ListView x:Name="SelectedTraineesListView"
                                  Grid.Row="1"
                                  SelectionMode="None"
                                  Visibility="Collapsed">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="44" Padding="16,4"
                                          Background="White"
                                          BorderBrush="#F0F0F0"
                                          BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Index}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TraineeId}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding FullName}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Nickname}"
                                                   FontSize="13" Foreground="#6B7280"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="4"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Width="34" Height="34" Padding="0"
                                                HorizontalAlignment="Center"
                                                Click="BtnRemoveTrainee_Click"
                                                Tag="{Binding TraineeId}">
                                            <FontIcon Glyph="&#xE74D;"
                                                      Foreground="#DC2626" FontSize="15"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══ Section 3: สรุป ═════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="White" CornerRadius="14"
                BorderBrush="#E5E7EB" BorderThickness="1"
                Margin="0,0,0,14">
            <Grid x:Name="SummaryGrid" Padding="20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4"
                            HorizontalAlignment="Center">
                    <TextBlock Text="จำนวนผู้สมัคร"
                               FontSize="13" Foreground="#9CA3AF"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTraineeCount"
                               Text="0 คน"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#1A1A2E"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="4"
                            HorizontalAlignment="Center">
                    <TextBlock Text="ราคาต่อคน"
                               FontSize="13" Foreground="#9CA3AF"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtPricePerPerson"
                               Text="฿0"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#1A1A2E"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="4"
                            HorizontalAlignment="Center">
                    <TextBlock Text="รวมทั้งหมด"
                               FontSize="13" Foreground="#9CA3AF"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalPrice"
                               Text="฿0"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#D32F2F"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Buttons ═════════════════════════════════════════ -->
        <Grid Grid.Row="4" Margin="0,0,0,40">
            <StackPanel x:Name="ButtonsPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="12">
                <Button x:Name="BtnCancel"
                        Background="White" Foreground="#4B5563"
                        BorderBrush="#E5E7EB" BorderThickness="1"
                        FontSize="16" Height="48"
                        Padding="32,0" CornerRadius="14"
                        Click="BtnBack_Click">
                    <TextBlock Text="ยกเลิก" FontWeight="SemiBold"/>
                </Button>
                <Button x:Name="BtnConfirm"
                        Background="#6C2BD9" Foreground="White"
                        FontSize="16" Height="48"
                        Padding="32,0" CornerRadius="14"
                        BorderThickness="0"
                        IsEnabled="False"
                        Click="BtnConfirm_Click">
                    <TextBlock Text="ยืนยันการสมัคร" FontWeight="Bold"/>
                </Button>
            </StackPanel>
        </Grid>

    </Grid>
    </ScrollViewer>
</Page>
