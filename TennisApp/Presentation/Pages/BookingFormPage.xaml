<Page
    x:Class="TennisApp.Presentation.Pages.BookingFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="40,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══ Header ══════════════════════════════════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Background="Transparent" BorderThickness="0"
                        Padding="0,0,12,0" Click="BtnBack_Click"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE76B;" FontSize="18" Foreground="#424242"/>
                        <TextBlock Text="กลับ" FontSize="15" Foreground="#424242"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1"
                           Text="จองสนาม"
                           FontSize="28" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
            </Grid>

            <!-- ══ Section 1: รายละเอียดการจอง ═════════════════ -->
            <Border Grid.Row="1"
                    Background="White" CornerRadius="8"
                    BorderBrush="#E0E0E0" BorderThickness="1"
                    Padding="32,24" Margin="0,0,0,20">
                <StackPanel Spacing="20">

                    <!-- Section Header -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Background="#4A148C" CornerRadius="14" Width="28" Height="28">
                            <TextBlock Text="1" FontSize="14" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="รายละเอียดการจอง"
                                   FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#F5F5F5" Height="1"/>

                    <!-- Date (full width) -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="วันที่ต้องการใช้งานสนาม" FontSize="14"/>
                            <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                        </StackPanel>
                        <DatePicker x:Name="FormDatePicker"
                                    Background="White" Height="42"
                                    HorizontalAlignment="Stretch"
                                    BorderBrush="#E0E0E0" CornerRadius="4"/>
                    </StackPanel>

                    <!-- Time + Duration (2 columns) -->
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="เวลาที่ต้องการใช้สนาม" FontSize="14"/>
                                <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                            </StackPanel>
                            <ComboBox x:Name="FormTimeComboBox"
                                      Background="White" Height="42"
                                      HorizontalAlignment="Stretch"
                                      BorderBrush="#E0E0E0" CornerRadius="4"
                                      PlaceholderText="เลือกเวลา" FontSize="14">
                                <ComboBoxItem Content="08:00" Tag="08:00"/>
                                <ComboBoxItem Content="09:00" Tag="09:00"/>
                                <ComboBoxItem Content="10:00" Tag="10:00"/>
                                <ComboBoxItem Content="11:00" Tag="11:00"/>
                                <ComboBoxItem Content="12:00" Tag="12:00"/>
                                <ComboBoxItem Content="13:00" Tag="13:00"/>
                                <ComboBoxItem Content="14:00" Tag="14:00"/>
                                <ComboBoxItem Content="15:00" Tag="15:00"/>
                                <ComboBoxItem Content="16:00" Tag="16:00"/>
                                <ComboBoxItem Content="17:00" Tag="17:00"/>
                                <ComboBoxItem Content="18:00" Tag="18:00"/>
                                <ComboBoxItem Content="19:00" Tag="19:00"/>
                                <ComboBoxItem Content="20:00" Tag="20:00"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="ระยะเวลาที่ต้องการใช้สนาม" FontSize="14"/>
                                <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                            </StackPanel>
                            <ComboBox x:Name="FormDurationComboBox"
                                      Background="White" Height="42"
                                      HorizontalAlignment="Stretch"
                                      BorderBrush="#E0E0E0" CornerRadius="4"
                                      PlaceholderText="เลือกระยะเวลา" FontSize="14">
                                <ComboBoxItem Content="1.0 ชม." Tag="1.0"/>
                                <ComboBoxItem Content="1.5 ชม." Tag="1.5"/>
                                <ComboBoxItem Content="2.0 ชม." Tag="2.0"/>
                                <ComboBoxItem Content="2.5 ชม." Tag="2.5"/>
                                <ComboBoxItem Content="3.0 ชม." Tag="3.0"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ══ Section 2: จุดประสงค์การใช้งาน ═══════════════ -->
            <Border Grid.Row="2"
                    Background="White" CornerRadius="8"
                    BorderBrush="#E0E0E0" BorderThickness="1"
                    Padding="32,24" Margin="0,0,0,20">
                <StackPanel Spacing="20">

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Background="#4A148C" CornerRadius="14" Width="28" Height="28">
                            <TextBlock Text="2" FontSize="14" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="จุดประสงค์การใช้งาน"
                                   FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#F5F5F5" Height="1"/>

                    <!-- Type (full width) -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="จุดประสงค์การใช้งาน" FontSize="14"/>
                            <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                        </StackPanel>
                        <ComboBox x:Name="FormTypeComboBox"
                                  Background="White" Height="42"
                                  HorizontalAlignment="Stretch"
                                  BorderBrush="#E0E0E0" CornerRadius="4"
                                  FontSize="14"
                                  SelectionChanged="FormTypeComboBox_SelectionChanged">
                            <ComboBoxItem Content="เช่าสนาม" Tag="Paid" IsSelected="True"/>
                            <ComboBoxItem Content="คอร์สเรียน" Tag="Course"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Course (full width, disabled by default) -->
                    <StackPanel x:Name="CoursePanel">
                        <TextBlock Text="คอร์สเรียน" FontSize="14" Margin="0,0,0,5"/>
                        <ComboBox x:Name="FormCourseComboBox"
                                  Background="White" Height="42"
                                  HorizontalAlignment="Stretch"
                                  BorderBrush="#E0E0E0" CornerRadius="4"
                                  FontSize="14"
                                  IsEnabled="False" Opacity="0.4"
                                  PlaceholderText="เลือกคอร์สเรียน (สำหรับจองคอร์ส)"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ══ Section 3: ข้อมูลผู้จอง ═════════════════════ -->
            <Border Grid.Row="3"
                    Background="White" CornerRadius="8"
                    BorderBrush="#E0E0E0" BorderThickness="1"
                    Padding="32,24" Margin="0,0,0,20">
                <StackPanel Spacing="20">

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Background="#4A148C" CornerRadius="14" Width="28" Height="28">
                            <TextBlock Text="3" FontSize="14" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ข้อมูลผู้จอง"
                                   FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#F5F5F5" Height="1"/>

                    <!-- Name (full width) -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="ชื่อผู้จอง" FontSize="14"/>
                            <TextBlock Text=" *" Foreground="#C62828" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBox x:Name="FormNameTextBox"
                                 PlaceholderText="กรอกชื่อผู้จอง"
                                 Background="White" Height="42"
                                 BorderBrush="#E0E0E0" CornerRadius="4"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Phone (full width) -->
                    <StackPanel>
                        <TextBlock Text="เบอร์โทรศัพท์" FontSize="14" Margin="0,0,0,5"/>
                        <TextBox x:Name="FormPhoneTextBox"
                                 PlaceholderText="0812345678"
                                 Background="White" Height="42"
                                 BorderBrush="#E0E0E0" CornerRadius="4"
                                 FontSize="14" MaxLength="10"
                                 InputScope="TelephoneNumber"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ══ Buttons ═════════════════════════════════════ -->
            <Grid Grid.Row="4" Margin="0,0,0,40">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="16">
                    <Button Content="ยกเลิก"
                            Background="White" Foreground="#424242"
                            BorderBrush="#E0E0E0" BorderThickness="1"
                            FontSize="16" Height="46"
                            Padding="32,0" CornerRadius="6"
                            Click="BtnBack_Click"/>
                    <Button Content="ยืนยันการจอง"
                            Background="#4A148C" Foreground="White"
                            FontSize="16" Height="46"
                            Padding="32,0" CornerRadius="6"
                            Click="BtnSubmit_Click"/>
                </StackPanel>
            </Grid>

        </Grid>
    </ScrollViewer>
</Page>
