<UserControl
    x:Class="TennisApp.Presentation.Shell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    RequestedTheme="Light">

    <Grid Background="White">
        <controls:NavigationView x:Name="NavView"
                         PaneDisplayMode="LeftCompact"
                         IsPaneToggleButtonVisible="True"
                         IsSettingsVisible="False"
                         IsPaneOpen="False"
                         CompactModeThresholdWidth="0"
                         ExpandedModeThresholdWidth="9999"
                         ItemInvoked="NavView_ItemInvoked"
                         Loaded="NavView_Loaded">

            <controls:NavigationView.PaneToggleButtonStyle>
                <Style TargetType="Button">
                    <Setter Property="Width" Value="56"/>
                    <Setter Property="Height" Value="56"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal"/>
                                            <VisualState x:Name="PointerOver">
                                                <VisualState.Setters>
                                                    <Setter Target="RootGrid.Background" Value="{ThemeResource NavigationViewButtonBackgroundPointerOver}"/>
                                                    <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource NavigationViewButtonForegroundPointerOver}"/>
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Pressed">
                                                <VisualState.Setters>
                                                    <Setter Target="RootGrid.Background" Value="{ThemeResource NavigationViewButtonBackgroundPressed}"/>
                                                    <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource NavigationViewButtonForegroundPressed}"/>
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    
                                    <ContentPresenter x:Name="ContentPresenter"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE700;" 
                                                  FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                  FontSize="20"/>
                                    </ContentPresenter>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </controls:NavigationView.PaneToggleButtonStyle>

            <!-- 🔹 เมนูทั้งหมด 9 ฟังก์ชัน -->
            <controls:NavigationView.MenuItems>

                <!-- 🏟 สนาม — Segoe Fluent: Stadium -->
                <controls:NavigationViewItem Tag="Court">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE707;" FontSize="18"/>
                    </controls:NavigationViewItem.Icon>
                    <TextBlock Text="จัดการพื้นที่สนาม" Foreground="Black"/>
                </controls:NavigationViewItem>

                <!-- 👤 ผู้ฝึกสอน — Person -->
                <controls:NavigationViewItem Tag="Trainer">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE77B;" FontSize="18"/>
                    </controls:NavigationViewItem.Icon>
                    <TextBlock Text="จัดการทะเบียนผู้ฝึกสอน" Foreground="Black"/>
                </controls:NavigationViewItem>

                <!-- 👥 ผู้เรียน — People group -->
                <controls:NavigationViewItem Tag="Trainee">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE716;" FontSize="18"/>
                    </controls:NavigationViewItem.Icon>
                    <TextBlock Text="จัดการทะเบียนผู้เรียน" Foreground="Black"/>
                </controls:NavigationViewItem>

                <!-- 📚 คอร์สเรียน — Book/Education -->
                <controls:NavigationViewItem Tag="Course">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE82D;" FontSize="18"/>
                    </controls:NavigationViewItem.Icon>
                    <TextBlock Text="จัดการคอร์สเรียน" Foreground="Black"/>
                </controls:NavigationViewItem>

                <!-- 📋 สมัครคอร์ส — Folded page -->
                <controls:NavigationViewItem Tag="RegisterCourse">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7C3;" FontSize="18"/>
                    </controls:NavigationViewItem.Icon>
                    <TextBlock Text="สมัครคอร์สเรียน" Foreground="Black"/>
                </controls:NavigationViewItem>

                <!-- 📅 จองเช่าสนาม — Calendar with dollar -->
                <controls:NavigationViewItem Tag="PaidBooking">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE787;" FontSize="18"/>
                    </controls:NavigationViewItem.Icon>
                    <TextBlock Text="จองเช่าสนาม" Foreground="Black"/>
                </controls:NavigationViewItem>

                <!-- 📅 จองสนามคอร์ส — Calendar with check -->
                <controls:NavigationViewItem Tag="CourseBooking">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE736;" FontSize="18"/>
                    </controls:NavigationViewItem.Icon>
                    <TextBlock Text="จองสนามคอร์ส" Foreground="Black"/>
                </controls:NavigationViewItem>

                <!-- ✅ บันทึกการใช้งาน — Checklist/Check-in -->
                <controls:NavigationViewItem Tag="UsageLog">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE73E;" FontSize="18"/>
                    </controls:NavigationViewItem.Icon>
                    <TextBlock Text="บันทึกการใช้งานสนาม" Foreground="Black"/>
                </controls:NavigationViewItem>

                <!-- 📊 สรุปผล — Chart/Dashboard -->
                <controls:NavigationViewItem Tag="Reports">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" FontSize="18"/>
                    </controls:NavigationViewItem.Icon>
                    <TextBlock Text="สรุปผลการดำเนินงาน" Foreground="Black"/>
                </controls:NavigationViewItem>

            </controls:NavigationView.MenuItems>

            <!-- 🔹 พื้นที่แสดงเนื้อหา + InfoBar -->
            <Grid>
                <Frame x:Name="ContentFrame"/>

                <!-- 🔔 Global InfoBar (ด้านบน — overlay) -->
                <controls:InfoBar x:Name="GlobalInfoBar"
                                  IsOpen="False"
                                  IsClosable="True"
                                  VerticalAlignment="Top"
                                  HorizontalAlignment="Stretch"
                                  Margin="12,8,12,0"
                                  CornerRadius="12"/>
            </Grid>
        </controls:NavigationView>
    </Grid>
</UserControl>
